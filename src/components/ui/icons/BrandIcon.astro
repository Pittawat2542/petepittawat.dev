---
import type { SimpleIcon } from 'simple-icons';

interface Props {
  icon: SimpleIcon;
  class?: string;
  title?: string;
  decorative?: boolean;
}

const { icon, class: className, title = icon.title, decorative = true } = Astro.props as Props;
---

<svg
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  role={decorative ? undefined : 'img'}
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={decorative ? undefined : title}
>
  <path d={icon.path}></path>
</svg>
