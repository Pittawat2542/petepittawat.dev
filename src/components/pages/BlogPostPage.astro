---
import { type CollectionEntry, render } from 'astro:content';
import RelatedPosts from '@/components/content/RelatedPosts';
import BlogPost from '@/layouts/BlogPost.astro';
import { getSuggestedReading } from '@/lib/blog-recommendations';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  isTranslationFallback?: boolean;
  otherLanguageSlug?: string;
}

const { post, isTranslationFallback, otherLanguageSlug } = Astro.props;
const { Content } = await render(post);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Rough reading time estimate (~220 wpm)
const wordCount = (post.body || '').trim().split(/\s+/).length;
const readingTimeMin = Math.max(1, Math.round(wordCount / 220));

// Wait, getting all blog posts here might be expensive, but it's static generation so it's ok.
// However, the original code used it for suggested reading. We should pass 'all' from the page or fetch here.
import { getCollection } from 'astro:content';
const all = (await getCollection('blog')) as CollectionEntry<'blog'>[];
const suggestedReading = getSuggestedReading(all, post);

const translationNotice = isTranslationFallback
  ? post.data.lang === 'th'
    ? t('blog.onlyInThai')
    : t('blog.onlyInEnglish')
  : null;
const translatedLink = otherLanguageSlug
  ? lang === 'th'
    ? `/blog/${otherLanguageSlug}`
    : `/th/blog/${otherLanguageSlug}`
  : null;
const translatedLinkLabel = lang === 'th' ? t('blog.readInEnglish') : t('blog.readInThai');
---

<BlogPost
  {...post.data}
  slug={post.data.slug}
  readingTimeMin={readingTimeMin}
  translationNotice={translationNotice}
  translatedLink={translatedLink}
  translatedLinkLabel={translatedLinkLabel}
>
  <Content />

  <Fragment slot="after">
    <RelatedPosts suggestions={suggestedReading} />
  </Fragment>
</BlogPost>
