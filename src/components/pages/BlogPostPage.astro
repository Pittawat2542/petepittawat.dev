---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import RelatedPosts from '@/components/content/RelatedPosts';
import BlogPost from '@/layouts/BlogPost.astro';
import { getSuggestedReading } from '@/lib/blog-recommendations';
import {
  getAlternateBlogPost,
  getBlogPostPath,
  getPreferredBlogPosts,
  getBlogPostRouteSlug,
  groupBlogPostsByTranslation,
} from '@/lib/blog-translations';
import { estimateReadingMetrics } from '@/lib/reading-time';

interface Props {
  post: CollectionEntry<'blog'>;
  alternatePost?: CollectionEntry<'blog'> | undefined;
}

const { post, alternatePost } = Astro.props;
const { Content } = await render(post);
const { readingTimeMin } = estimateReadingMetrics(post.body || '');

const all = (await getCollection('blog')) as CollectionEntry<'blog'>[];
const groupedPosts = groupBlogPostsByTranslation(all);
const suggestedReading = getSuggestedReading(
  getPreferredBlogPosts(groupedPosts, post.data.lang),
  post
);
const siblingPost = alternatePost ?? getAlternateBlogPost(post, groupedPosts);
const translatedLink = siblingPost ? getBlogPostPath(siblingPost) : null;
const translatedLinkLabel = siblingPost
  ? `Read this post in ${siblingPost.data.lang === 'th' ? 'Thai' : 'English'}`
  : null;
const alternateLanguages = siblingPost
  ? [{ lang: siblingPost.data.lang, href: translatedLink! }]
  : [];
---

<BlogPost
  {...post.data}
  slug={getBlogPostRouteSlug(post)}
  lang={post.data.lang}
  readingTimeMin={readingTimeMin}
  translatedLink={translatedLink}
  translatedLinkLabel={translatedLinkLabel}
  alternateLanguages={alternateLanguages}
>
  <Content />

  <Fragment slot="after">
    <RelatedPosts suggestions={suggestedReading} />
  </Fragment>
</BlogPost>
