---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/lib/constants';
import PageBackdrop from '@/components/layout/core/PageBackdrop.astro';
import Container from '@/components/ui/core/Container.astro';
import AboutBackground from '@/components/pages/about/AboutBackground.astro';
import AboutCurrentWork from '@/components/pages/about/AboutCurrentWork.astro';
import AboutHero from '@/components/pages/about/AboutHero.astro';
import AboutMilestones from '@/components/pages/about/AboutMilestones.astro';
import AboutProofPoints from '@/components/pages/about/AboutProofPoints.astro';
import AboutThemes from '@/components/pages/about/AboutThemes.astro';
import { siteCopyEn } from '@/data/site/copy';
import { getAboutTimeline } from '@/lib/content';
import '@/styles/components/about-page.css';

const aboutCopy = siteCopyEn.about;
const aboutPage = siteCopyEn.listingPages.about;
const timeline = await getAboutTimeline();
const spotlightTimeline = timeline.filter(item => item.highlight);
---

<BaseLayout
  title={`${SITE_CONFIG.title} - ${aboutPage.title}`}
  description={aboutPage.metaDescription || SITE_CONFIG.description}
  page="about"
>
  <PageBackdrop variant="landing" />
  <Container className="about-page space-y-12 pt-2 pb-24 lg:space-y-16">
    <AboutHero aboutCopy={aboutCopy} />
    <AboutProofPoints proofPoints={aboutCopy.proofPoints} />
    <AboutThemes focusAreas={aboutCopy.focusAreas} />
    <AboutCurrentWork currentWork={aboutCopy.currentWork} />
    <AboutBackground background={aboutCopy.background} />
    <AboutMilestones
      milestones={aboutCopy.milestones}
      spotlightTimeline={spotlightTimeline}
      timeline={timeline}
    />
  </Container>
</BaseLayout>
