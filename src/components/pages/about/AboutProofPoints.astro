---
import { BadgeCheck, BriefcaseBusiness, Globe, Workflow } from 'lucide-react';
import GlassCard from '@/components/ui/core/GlassCard.astro';

interface Props {
  proofPoints: {
    title: string;
    items: ReadonlyArray<{
      label: string;
      value: string;
      hint: string;
    }>;
  };
}

const { proofPoints } = Astro.props as Props;
// NOTE: Index-based coupling between proofIcons and the proofPoints items:
// - Index 0: BriefcaseBusiness (typically experience-related label)
// - Index 1: Workflow (typically project/working style label)
// - Index 2: Globe (typically location/base label)
// Fallback icon is BadgeCheck. Ensure the copy order in copy.ts remains aligned.
const proofIcons = [BriefcaseBusiness, Workflow, Globe] as const;
---

<section id="proof-points" class="section-block reveal">
  <div class="section-heading">
    <div class="mb-2 flex items-center gap-2">
      <BadgeCheck className="h-5 w-5 text-[color:var(--accent)]" />
      <h2>{proofPoints.title}</h2>
    </div>
    <p>The fastest way to understand what I do, how I work, and where I am operating from.</p>
  </div>

  <div class="proof-grid">
    {
      proofPoints.items.map((item, index) => {
        const Icon = proofIcons[index] || BadgeCheck;
        return (
          <GlassCard variant="premium" className="proof-card">
            <div class="proof-card__icon" aria-hidden="true">
              <Icon className="h-8 w-8" />
            </div>
            <div class="proof-card__content">
              <p class="proof-card__label">{item.label}</p>
              <p class="proof-card__value">{item.value}</p>
              <p class="proof-card__hint">{item.hint}</p>
            </div>
          </GlassCard>
        );
      })
    }
  </div>
</section>
