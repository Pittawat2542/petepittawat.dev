---
import { Activity, Flame, Globe, Layers, ShieldCheck } from '@lucide/astro';
import GlassCard from '@/components/ui/core/GlassCard.astro';
import type { ResearchThemeIcon } from '@/data/site/copy';

interface Props {
  focusAreas: {
    title: string;
    description: string;
    items: ReadonlyArray<{
      title: string;
      description: string;
      icon: ResearchThemeIcon;
    }>;
  };
}

const { focusAreas } = Astro.props as Props;
const themeIconMap = {
  activity: Activity,
  layers: Layers,
  'shield-check': ShieldCheck,
  globe: Globe,
} as const;
---

<section id="themes" class="section-block reveal">
  <div class="section-heading">
    <div class="mb-2 flex items-center gap-2">
      <Flame class="h-5 w-5 text-[color:var(--accent)]" />
      <h2>{focusAreas.title}</h2>
    </div>
    <p>{focusAreas.description}</p>
  </div>
  <div class="themes-grid">
    {
      focusAreas.items.map(theme => {
        const Icon = themeIconMap[theme.icon];
        return (
          <GlassCard variant="premium" className="theme-card">
            <div class="theme-card__icon" aria-hidden="true">
              <Icon class="h-9 w-9" />
            </div>
            <h3>{theme.title}</h3>
            <p>{theme.description}</p>
          </GlassCard>
        );
      })
    }
  </div>
</section>
