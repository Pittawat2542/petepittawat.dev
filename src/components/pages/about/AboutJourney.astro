---
import { Milestone } from '@lucide/astro';
import GlassCard from '@/components/ui/core/GlassCard.astro';
import type { AboutTimelineItem } from '@/lib/content';

interface Props {
  journey: {
    title: string;
    description: string;
    spotlightTitle: string;
    educationTitle: string;
    educationEntries: ReadonlyArray<{
      title: string;
      period: string;
      summary: string;
    }>;
    collaborationsTitle: string;
    communityHighlights: ReadonlyArray<{
      title: string;
      description: string;
      bullets: readonly string[];
    }>;
    serviceTitle: string;
    serviceHighlights: readonly string[];
    learningHighlights: readonly string[];
    extendedTimelineLabel: string;
  };
  spotlightTimeline: readonly AboutTimelineItem[];
  timeline: readonly AboutTimelineItem[];
}

const { journey, spotlightTimeline, timeline } = Astro.props as Props;
---

<section id="journey" class="section-block">
  <div class="section-heading">
    <div class="mb-2 flex items-center gap-2">
      <Milestone class="h-5 w-5 text-[color:var(--accent)]" />
      <h2>{journey.title}</h2>
    </div>
    <p>{journey.description}</p>
  </div>

  <div class="journey-grid">
    <GlassCard variant="glow" className="spotlight-card">
      <span class="eyebrow">{journey.spotlightTitle}</span>
      <ol>
        {
          spotlightTimeline.map(item => (
            <li>
              <p class="spotlight-card__title">{item.title}</p>
              <p class="spotlight-card__description">{item.description}</p>
            </li>
          ))
        }
      </ol>
    </GlassCard>

    <GlassCard variant="premium" className="journey-card">
      <h3>{journey.educationTitle}</h3>
      <div class="journey-card__group">
        {
          journey.educationEntries.map(entry => (
            <div>
              <div class="journey-card__header">
                <p>{entry.title}</p>
                <span>{entry.period}</span>
              </div>
              <p class="journey-card__summary">{entry.summary}</p>
            </div>
          ))
        }
      </div>
    </GlassCard>

    <GlassCard variant="premium" className="journey-card">
      <h3>{journey.collaborationsTitle}</h3>
      <div class="journey-card__group">
        {
          journey.communityHighlights.map(item => (
            <div>
              <p class="journey-card__subhead">{item.title}</p>
              <p class="journey-card__summary">{item.description}</p>
              <ul class="journey-card__list">
                {item.bullets.map(point => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </GlassCard>

    <GlassCard variant="premium" className="journey-card">
      <h3>{journey.serviceTitle}</h3>
      <ul class="journey-card__list">
        {journey.serviceHighlights.map(point => <li>{point}</li>)}
      </ul>
      <ul class="journey-card__list journey-card__list--muted">
        {journey.learningHighlights.map(point => <li>{point}</li>)}
      </ul>
    </GlassCard>
  </div>

  <details class="timeline-details">
    <summary>{journey.extendedTimelineLabel}</summary>
    <ol>
      {
        timeline.map(item => (
          <li>
            <p class="timeline-details__title">{item.title}</p>
            <p class="timeline-details__description">{item.description}</p>
          </li>
        ))
      }
    </ol>
  </details>
</section>
