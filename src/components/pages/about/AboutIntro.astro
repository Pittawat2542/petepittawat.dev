---
import { Image } from 'astro:assets';
import { MapPin, Sparkles } from '@lucide/astro';
import profileImage from '@/assets/images/profile.jpg';
import GlassCard from '@/components/ui/core/GlassCard.astro';
import { socialLinks } from '@/components/layout/core/footer-social-links';

interface Props {
  aboutCopy: {
    intro: {
      eyebrow: string;
      role: string;
      location: string;
      summary: string;
    };
  };
}

const { aboutCopy } = Astro.props as Props;
const featuredLinks = socialLinks.filter(link =>
  ['LinkedIn', 'GitHub', 'Google Scholar', 'ORCID'].includes(link.label)
);
---

<section id="intro" class="intro-grid">
  <GlassCard variant="premium" className="profile-card">
    <div class="profile-card__header">
      <div class="profile-card__portrait">
        <Image
          src={profileImage}
          alt="Pete's profile picture"
          widths={[160, 200, 260, 320]}
          sizes="(min-width: 1024px) 7rem, (min-width: 768px) 6rem, 5.5rem"
          loading="lazy"
          decoding="async"
          class="profile-card__image"
        />
      </div>
      <div class="profile-card__meta">
        <span class="eyebrow">{aboutCopy.intro.eyebrow}</span>
        <p class="profile-card__role">{aboutCopy.intro.role}</p>
        <p class="profile-card__location">
          <MapPin class="h-3.5 w-3.5" aria-hidden="true" />
          <span>{aboutCopy.intro.location}</span>
        </p>
      </div>
    </div>
    <div class="profile-card__body">
      <h2>Hi, I&apos;m Pittawat (Pete).</h2>
      <p>{aboutCopy.intro.summary}</p>
    </div>
    <div class="profile-card__links" aria-label="Connect">
      {
        featuredLinks.map(link => (
          <a class="profile-card__link" href={link.href} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))
      }
    </div>
  </GlassCard>

  <div class="intro-grid__aside">
    <GlassCard variant="premium" className="now-card relative overflow-hidden">
      <div
        class="pointer-events-none absolute -top-6 -right-6 h-32 w-32 rounded-full bg-[color:var(--accent)]/10 blur-2xl"
      >
      </div>
      <div class="relative z-10">
        <div class="mb-4 flex items-center gap-2">
          <Sparkles class="h-4 w-4 text-[color:var(--accent)]" />
          <span class="eyebrow text-[color:var(--accent)]">Why this page exists</span>
        </div>
        <ul class="space-y-3">
          <li class="flex gap-3 text-sm leading-relaxed text-[color:var(--white)]/80">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--accent)]/60"
            ></span>
            Built for fast scanning by recruiters, hiring managers, and technical collaborators.
          </li>
          <li class="flex gap-3 text-sm leading-relaxed text-[color:var(--white)]/80">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--accent)]/60"
            ></span>
            Focused on what I work on, how I think, and where I have built credibility.
          </li>
          <li class="flex gap-3 text-sm leading-relaxed text-[color:var(--white)]/80">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[color:var(--accent)]/60"
            ></span>
            Meant to complement the deeper evidence on the projects, publications, talks, and blog pages.
          </li>
        </ul>
      </div>
    </GlassCard>
  </div>
</section>
