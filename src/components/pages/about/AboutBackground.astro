---
import { BookOpenText, History, Lightbulb, UsersRound } from '@lucide/astro';
import GlassCard from '@/components/ui/core/GlassCard.astro';

interface Props {
  background: {
    title: string;
    description: string;
    paragraphs: readonly string[];
  };
}

const { background } = Astro.props as Props;
const principleIcons = [BookOpenText, Lightbulb, UsersRound] as const;
const principleLabels = ['What I study', 'How I think', 'Why it matters'] as const;
---

<section id="background" class="section-block reveal relative">
  <div class="section-heading">
    <div class="mb-2 flex items-center gap-2">
      <History class="h-5 w-5 text-[color:var(--accent)]" />
      <h2>{background.title}</h2>
    </div>
    <p>{background.description}</p>
  </div>

  <GlassCard variant="premium" className="background-band">
    <div class="background-principles">
      {
        background.paragraphs.map((note, index) => {
          const Icon = principleIcons[index] || History;
          return (
            <article class="background-principle">
              <div class="background-principle__icon" aria-hidden="true">
                <Icon class="h-7 w-7" />
              </div>
              <div>
                <h3>{principleLabels[index] || background.title}</h3>
                <p>{note}</p>
              </div>
            </article>
          );
        })
      }
    </div>
    <div class="background-layers" aria-hidden="true">
      <span class="background-layers__plane background-layers__plane--top"></span>
      <span class="background-layers__plane background-layers__plane--middle"></span>
      <span class="background-layers__plane background-layers__plane--bottom"></span>
      <span class="background-layers__mesh"></span>
    </div>
  </GlassCard>
</section>
