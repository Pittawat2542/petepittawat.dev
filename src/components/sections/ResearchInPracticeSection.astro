---
import Container from '@/components/ui/core/Container.astro';
import type { SiteCopy } from '@/data/site/copy';
import { Activity, ArrowRight, BrainCircuit, ChartColumn, Network } from '@lucide/astro';

interface Props {
  copy: SiteCopy['home']['researchInPractice'];
}

const { copy } = Astro.props as Props;

const pillarIcons = {
  activity: Activity,
  'chart-column': ChartColumn,
  'brain-circuit': BrainCircuit,
  network: Network,
} as const;

const pillarAccents = ['#60a5fa', '#818cf8', '#c084fc', '#67e8f9'] as const;

const pillarItems = copy.pillars.map((pillar, index) => ({
  ...pillar,
  Icon: pillarIcons[pillar.icon],
  style: `--pillar-accent: ${pillarAccents[index] ?? pillarAccents[0]}`,
}));
---

<Container className="reveal mt-16">
  <section id="about" class="research-practice" aria-labelledby="research-practice-title">
    <div class="research-practice__ambient" aria-hidden="true"></div>
    <div class="research-practice__intro">
      <p class="research-practice__eyebrow">{copy.eyebrow}</p>
      <h2 id="research-practice-title" class="research-practice__title">
        <span>{copy.title}</span>
        <span class="research-practice__title-accent">{copy.titleAccent}</span>
      </h2>
      <p class="research-practice__body">{copy.body}</p>
      <a class="research-practice__link" href={copy.ctaHref}>
        <span>{copy.ctaLabel}</span>
        <ArrowRight class="research-practice__link-icon" aria-hidden="true" />
      </a>
    </div>

    <div class="research-practice__pillars" aria-label="Research focus areas">
      {
        pillarItems.map(({ title, description, Icon, style }) => (
          <article class="research-practice__pillar" style={style}>
            <div class="research-practice__pillar-icon-shell" aria-hidden="true">
              <Icon class="research-practice__pillar-icon" />
            </div>
            <h3>{title}</h3>
            <p>{description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Container>

<style>
  .research-practice {
    --research-panel-bg:
      radial-gradient(circle at 12% 12%, rgba(96, 165, 250, 0.06), transparent 28rem),
      radial-gradient(circle at 85% 18%, rgba(129, 140, 248, 0.05), transparent 24rem),
      linear-gradient(180deg, rgba(15, 23, 42, 0.36), rgba(8, 13, 27, 0.22));
    --research-panel-border: color-mix(in oklab, var(--white) 8%, transparent);
    --research-panel-divider: color-mix(in oklab, var(--white) 8%, transparent);
    --research-panel-muted: color-mix(in oklab, var(--white) 66%, transparent);
    --research-panel-strong: color-mix(in oklab, var(--white) 94%, transparent);
    --research-panel-accent: #6aa8ff;
    --research-panel-padding: clamp(1.35rem, 3vw, 2.65rem);
    --research-panel-column-gap: clamp(1rem, 2.6vw, 2.4rem);
    --research-tile-bg: color-mix(in oklab, var(--white) 3.2%, rgba(9, 16, 32, 0.22));
    --research-tile-border: color-mix(in oklab, var(--white) 7.5%, transparent);

    position: relative;
    display: grid;
    gap: var(--research-panel-column-gap);
    overflow: hidden;
    border: 1px solid var(--research-panel-border);
    border-radius: clamp(1.35rem, 3vw, 2rem);
    background: var(--research-panel-bg);
    box-shadow:
      0 18px 44px -38px rgba(2, 8, 23, 0.88),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    padding: var(--research-panel-padding);
    isolation: isolate;
  }

  .research-practice::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.018),
        transparent 18%,
        transparent 86%,
        rgba(255, 255, 255, 0.014)
      ),
      linear-gradient(180deg, rgba(255, 255, 255, 0.026), transparent 42%);
    opacity: 0.72;
    pointer-events: none;
  }

  .research-practice__ambient {
    position: absolute;
    inset: -30%;
    z-index: -2;
    background:
      radial-gradient(circle at 34% 22%, rgba(96, 165, 250, 0.07), transparent 34%),
      radial-gradient(circle at 74% 62%, rgba(192, 132, 252, 0.055), transparent 30%);
    filter: blur(32px);
    opacity: 0.55;
    pointer-events: none;
  }

  .research-practice__intro {
    position: relative;
    max-width: 35rem;
    align-self: center;
  }

  .research-practice__eyebrow {
    margin: 0 0 0.85rem;
    color: color-mix(in oklab, var(--research-panel-accent) 72%, var(--white) 24%);
    font-size: var(--type-meta);
    font-weight: 760;
    letter-spacing: 0.2em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .research-practice__title {
    display: flex;
    max-width: 13ch;
    flex-direction: column;
    margin: 0;
    color: var(--research-panel-strong);
    font-size: var(--type-section-title);
    font-weight: 740;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .research-practice__title-accent {
    color: var(--research-panel-accent);
    text-shadow: 0 0 16px color-mix(in oklab, var(--research-panel-accent) 22%, transparent);
  }

  .research-practice__body {
    max-width: 35rem;
    margin: 1.25rem 0 0;
    color: color-mix(in oklab, var(--white) 61%, transparent);
    font-size: var(--type-body);
    line-height: 1.74;
  }

  .research-practice__link {
    display: inline-flex;
    min-height: 2.7rem;
    width: fit-content;
    align-items: center;
    justify-content: center;
    gap: 0.62rem;
    margin-top: 1.6rem;
    border: 1px solid color-mix(in oklab, var(--white) 11%, var(--research-panel-accent) 10%);
    border-radius: 999px;
    background:
      radial-gradient(circle at 18% 50%, rgba(96, 165, 250, 0.11), transparent 42%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.014)),
      color-mix(in oklab, var(--black-nav) 72%, transparent);
    box-shadow:
      0 12px 26px -24px rgba(96, 165, 250, 0.44),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    color: color-mix(in oklab, var(--research-panel-accent) 82%, var(--white) 18%);
    font-size: var(--type-body-sm);
    font-weight: 700;
    line-height: 1.2;
    padding: 0.3rem 1.05rem 0.3rem 1.15rem;
    text-decoration: none;
    transition:
      color var(--motion-duration-fast) var(--motion-ease-decelerate),
      transform var(--motion-duration-fast) var(--motion-ease-decelerate),
      border-color var(--motion-duration-fast) var(--motion-ease-decelerate),
      box-shadow var(--motion-duration-fast) var(--motion-ease-decelerate);
  }

  .research-practice__link:hover,
  .research-practice__link:focus-visible {
    border-color: color-mix(in oklab, var(--research-panel-accent) 34%, var(--white) 10%);
    box-shadow:
      0 16px 32px -26px color-mix(in oklab, var(--research-panel-accent) 58%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    color: var(--white);
    transform: translate3d(0, -0.04rem, 0);
  }

  .research-practice__link:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--research-panel-accent) 48%, transparent);
    outline-offset: 0.28rem;
  }

  .research-practice__link-icon {
    width: 1rem;
    height: 1rem;
    transition: transform var(--motion-duration-fast) var(--motion-ease-decelerate);
  }

  .research-practice__link:hover .research-practice__link-icon,
  .research-practice__link:focus-visible .research-practice__link-icon {
    transform: translate3d(0.16rem, 0, 0);
  }

  .research-practice__pillars {
    display: grid;
    gap: 0.75rem;
  }

  .research-practice__pillar {
    --pillar-accent: var(--research-panel-accent);
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 10rem;
    gap: 0.72rem;
    overflow: hidden;
    border: 1px solid var(--research-tile-border);
    border-radius: clamp(1rem, 2vw, 1.35rem);
    background:
      radial-gradient(
        circle at 14% 8%,
        color-mix(in oklab, var(--pillar-accent) 7.5%, transparent),
        transparent 48%
      ),
      linear-gradient(180deg, color-mix(in oklab, var(--white) 3.5%, transparent), transparent 72%),
      var(--research-tile-bg);
    box-shadow:
      0 14px 30px -32px rgba(0, 0, 0, 0.76),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
    padding: clamp(0.95rem, 2vw, 1.25rem);
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-decelerate),
      background-color var(--motion-duration-fast) var(--motion-ease-decelerate),
      transform var(--motion-duration-fast) var(--motion-ease-decelerate);
  }

  .research-practice__pillar + .research-practice__pillar {
    margin-top: 0;
  }

  .research-practice__pillar-icon-shell {
    display: inline-flex;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklab, var(--pillar-accent) 22%, var(--white) 7%);
    border-radius: 0.86rem;
    background:
      radial-gradient(
        circle at 30% 20%,
        color-mix(in oklab, var(--pillar-accent) 13%, transparent),
        transparent 58%
      ),
      color-mix(in oklab, var(--black) 34%, transparent);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045);
  }

  .research-practice__pillar-icon {
    width: 1.45rem;
    height: 1.45rem;
    color: var(--pillar-accent);
    filter: drop-shadow(0 0 9px color-mix(in oklab, var(--pillar-accent) 28%, transparent));
    stroke-width: 1.7;
  }

  .research-practice__pillar h3 {
    margin: 0;
    color: var(--research-panel-strong);
    font-size: var(--type-body-sm);
    font-weight: 760;
    line-height: 1.25;
  }

  .research-practice__pillar p {
    margin: 0;
    color: color-mix(in oklab, var(--white) 56%, transparent);
    font-size: var(--type-control);
    line-height: 1.58;
  }

  .research-practice__pillar:hover {
    border-color: color-mix(in oklab, var(--pillar-accent) 18%, var(--white) 8%);
    transform: translate3d(0, -0.04rem, 0);
  }

  @media (min-width: 768px) {
    .research-practice__pillars {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .research-practice__pillar {
      min-height: 11.2rem;
    }
  }

  @media (min-width: 1024px) {
    .research-practice {
      grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
      align-items: center;
      min-height: 22rem;
    }

    .research-practice__pillars {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.95rem;
    }

    .research-practice__body {
      max-width: 34rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .research-practice__link,
    .research-practice__link-icon,
    .research-practice__pillar {
      transition: none;
    }

    .research-practice__link:hover,
    .research-practice__link:focus-visible,
    .research-practice__link:hover .research-practice__link-icon,
    .research-practice__link:focus-visible .research-practice__link-icon,
    .research-practice__pillar:hover {
      transform: none;
    }
  }
</style>
