---
import Container from '@/components/ui/core/Container.astro';
import { BlogCard } from '@/components/ui/cards/BlogCard';
import GlassButton from '@/components/ui/navigation/GlassButton';
import { ArrowRight } from '@lucide/astro';
import type { BlogPost } from '@/types';
import type { SiteCopy } from '@/data/site/copy';
import { estimateReadingMetrics } from '@/lib/reading-time';

interface Props {
  posts: BlogPost[];
  allPosts?: BlogPost[];
  copy: SiteCopy['home']['blogSection'];
}

const { posts, allPosts, copy } = Astro.props as Props;
const featuredPost = posts[0];
const compactPosts = posts.slice(1, 3);
const titleLines = copy.title.includes('research and engineering loop')
  ? ['Recent notes from the research', 'and engineering loop']
  : [copy.title];
const getReadingTimeMin = (post: BlogPost | undefined) =>
  post ? estimateReadingMetrics(post.body || '').readingTimeMin : undefined;
---

<!-- Latest from the Blog -->
<Container
  className="latest-writing reveal glass-section mt-20"
  aria-labelledby="latest-writing-title"
>
  <div class="latest-writing__header">
    <div class="latest-writing__intro">
      <div class="section-eyebrow latest-writing__eyebrow">
        <span class="section-eyebrow__dot"></span>
        {copy.eyebrow}
      </div>
      <h2 id="latest-writing-title" class="latest-writing__title">
        {
          titleLines.map((line, index) => (
            <>
              <span>{line}</span>
              {index < titleLines.length - 1 ? ' ' : ''}
            </>
          ))
        }
      </h2>
      <p class="latest-writing__description">
        {copy.description}
      </p>
    </div>
    <GlassButton className="latest-writing__button" href="/blog" variant="ghost" size="md">
      {copy.browseLabel}
      <ArrowRight class="h-4 w-4" aria-hidden="true" />
    </GlassButton>
  </div>
  {
    posts.length === 0 ? (
      <div class="shape-squircle rounded-2xl border border-white/10 bg-white/5 px-6 py-10 text-center text-[color:var(--white)]/70">
        {copy.emptyLabel}
      </div>
    ) : (
      <ul class="latest-blog" id="latest-blog">
        {featuredPost ? (
          <BlogCard
            post={featuredPost}
            allPosts={allPosts || undefined}
            presentation="featured"
            readingTimeMin={getReadingTimeMin(featuredPost)}
          />
        ) : null}
        {compactPosts.map(post => (
          <BlogCard
            post={post}
            allPosts={allPosts || undefined}
            presentation="compact"
            readingTimeMin={getReadingTimeMin(post)}
          />
        ))}
      </ul>
    )
  }
</Container>

<style>
  .latest-writing {
    --latest-writing-gap: clamp(1rem, 2.2vw, 1.75rem);
    padding-top: clamp(0.25rem, 1vw, 0.75rem);
  }

  .latest-writing__header {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: clamp(1.4rem, 4vw, 3rem);
    margin-bottom: clamp(2.1rem, 4.2vw, 3.4rem);
  }

  .latest-writing__intro {
    max-width: 66rem;
    min-width: 0;
  }

  .latest-writing__eyebrow {
    margin-bottom: clamp(1rem, 1.6vw, 1.25rem);
  }

  .latest-writing__title {
    margin: 0;
    color: var(--white);
    overflow-wrap: normal;
    font-size: clamp(2.15rem, 3.55vw, 3.25rem);
    font-weight: 760;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .latest-writing__title span {
    display: block;
  }

  .latest-writing__description {
    max-width: 62rem;
    margin: clamp(1.2rem, 2vw, 1.55rem) 0 0;
    color: color-mix(in oklab, var(--white) 66%, transparent);
    font-size: var(--type-body-lg);
    line-height: 1.68;
  }

  :global(.latest-writing__button) {
    min-width: max-content;
    border-color: color-mix(in oklab, var(--white) 12%, var(--accent-blog) 14%);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.014)),
      rgba(15, 23, 42, 0.28);
    color: color-mix(in oklab, var(--white) 78%, transparent);
    white-space: nowrap;
  }

  .latest-blog {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--latest-writing-gap);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (min-width: 1024px) {
    .latest-blog {
      grid-template-columns: minmax(0, 1.28fr) minmax(22rem, 0.92fr);
      grid-auto-rows: minmax(0, 1fr);
      align-items: stretch;
    }

    :global(.latest-blog__featured-item) {
      grid-row: span 2;
    }
  }

  @media (max-width: 767px) {
    .latest-writing__header {
      grid-template-columns: minmax(0, 1fr);
      align-items: flex-start;
    }

    .latest-writing__title {
      max-width: 100%;
      font-size: clamp(1.85rem, 8vw, 2.35rem);
      line-height: 1.03;
    }

    :global(.latest-writing__button) {
      width: 100%;
    }
  }
</style>
