---
import { ArrowRight } from '@lucide/astro';

type CtaIcon = (typeof import('@lucide/astro'))['BookText'];

interface CtaToken {
  readonly accent: string;
  readonly accentMuted: string;
  readonly glow: string;
}

interface Props {
  readonly href: string;
  readonly title: string;
  readonly description: string;
  readonly ctaLabel: string;
  readonly Icon: CtaIcon;
  readonly token: CtaToken;
}

const { href, title, description, ctaLabel, Icon, token } = Astro.props as Props;
---

<a
  href={href}
  class="hero-cta-card shape-squircle"
  style={{
    '--hero-cta-accent': token.accent,
    '--hero-cta-accent-muted': token.accentMuted,
    '--hero-cta-glow': token.glow,
  }}
>
  <span class="hero-cta-card__shine" aria-hidden="true"></span>
  <span class="hero-cta-card__header">
    <span class="hero-cta-card__icon-shell" aria-hidden="true">
      <Icon class="hero-cta-card__icon" aria-hidden="true" />
    </span>
    <span class="hero-cta-card__title">{title}</span>
  </span>

  <span class="hero-cta-card__description">{description}</span>

  <span class="hero-cta-card__divider" aria-hidden="true"></span>

  <span class="hero-cta-card__link">
    <span>{ctaLabel}</span>
    <ArrowRight class="hero-cta-card__arrow" aria-hidden="true" />
  </span>
</a>

<style>
  .hero-cta-card {
    --hero-cta-card-radius: clamp(1.18rem, 2.6vw, 1.58rem);
    --hero-cta-card-border: color-mix(in oklab, var(--hero-cta-accent) 31%, var(--white) 6%);
    --hero-cta-card-border-active: color-mix(in oklab, var(--hero-cta-accent) 62%, var(--white) 9%);
    --hero-cta-card-bg:
      radial-gradient(
        circle at 9% 8%,
        color-mix(in oklab, var(--hero-cta-accent) 18%, transparent),
        transparent 34%
      ),
      radial-gradient(
        circle at 80% 0%,
        color-mix(in oklab, var(--hero-cta-accent) 8%, transparent),
        transparent 38%
      ),
      var(--output-card-bg);
    --hero-cta-card-text: var(--output-card-text);
    --hero-cta-card-muted: var(--output-card-muted);
    --hero-cta-card-shadow:
      0 24px 62px -46px var(--hero-cta-glow), 0 18px 42px -34px rgba(0, 0, 0, 0.88),
      inset 0 1px 0 rgba(255, 255, 255, 0.075);

    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: auto minmax(0, 1fr) auto auto;
    align-content: stretch;
    align-items: start;
    row-gap: clamp(0.66rem, 1.15vw, 0.88rem);
    min-height: clamp(9.8rem, 12.6vw, 11.4rem);
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--hero-cta-card-border);
    border-radius: var(--hero-cta-card-radius);
    background: var(--hero-cta-card-bg);
    box-shadow: var(--hero-cta-card-shadow);
    padding: clamp(1.32rem, 2.2vw, 1.72rem) clamp(1.22rem, 2.15vw, 1.6rem);
    color: var(--hero-cta-card-text);
    text-decoration: none;
    transition:
      border-color var(--motion-duration-normal) var(--motion-ease-decelerate),
      background var(--motion-duration-normal) var(--motion-ease-decelerate),
      box-shadow var(--motion-duration-normal) var(--motion-ease-decelerate),
      transform var(--motion-duration-normal) var(--motion-ease-decelerate);
  }

  .hero-cta-card::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: '';
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.072), transparent 24%),
      radial-gradient(circle at 11% 14%, var(--hero-cta-accent-muted), transparent 32%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.026), transparent 44%);
    opacity: 0.72;
    transition: opacity var(--motion-duration-normal) ease;
  }

  .hero-cta-card::after {
    position: absolute;
    inset: auto 8% -1px;
    height: 2px;
    content: '';
    background: linear-gradient(90deg, transparent, var(--hero-cta-accent), transparent);
    filter: blur(0.5px);
    opacity: 0.42;
    pointer-events: none;
  }

  .hero-cta-card__shine {
    position: absolute;
    inset: 0 12% auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--hero-cta-accent), transparent);
    opacity: 0.46;
  }

  .hero-cta-card__icon-shell {
    position: relative;
    display: grid;
    width: clamp(2.28rem, 3vw, 2.5rem);
    height: clamp(2.28rem, 3vw, 2.5rem);
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid color-mix(in oklab, var(--hero-cta-accent) 46%, rgba(255, 255, 255, 0.1));
    border-radius: 0.86rem;
    background:
      radial-gradient(circle at 50% 50%, var(--hero-cta-accent-muted), transparent 64%),
      radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.08), transparent 48%),
      rgba(12, 23, 45, 0.5);
    color: var(--hero-cta-accent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.11),
      0 0 1.34rem -0.48rem var(--hero-cta-glow);
    transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    transition:
      border-color var(--motion-duration-normal) var(--motion-ease-decelerate),
      box-shadow var(--motion-duration-normal) var(--motion-ease-decelerate),
      transform var(--motion-duration-normal) var(--motion-ease-decelerate);
  }

  .hero-cta-card__icon {
    width: clamp(1rem, 1.34vw, 1.2rem);
    height: clamp(1rem, 1.34vw, 1.2rem);
    filter: drop-shadow(0 0 8px var(--hero-cta-glow));
    stroke-width: 1.85;
    transition: transform var(--motion-duration-normal) var(--motion-ease-decelerate);
  }

  .hero-cta-card__header,
  .hero-cta-card__description,
  .hero-cta-card__divider,
  .hero-cta-card__link {
    grid-column: 1 / -1;
    position: relative;
    z-index: 1;
  }

  .hero-cta-card__header {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: clamp(0.68rem, 1.05vw, 0.9rem);
  }

  .hero-cta-card__title {
    display: block;
    min-width: 0;
    color: color-mix(in oklab, var(--white) 97%, transparent);
    font-size: clamp(1.3rem, 1.58vw, 1.62rem);
    font-weight: 820;
    line-height: 1.08;
    letter-spacing: 0;
    text-align: left;
    text-wrap: balance;
  }

  .hero-cta-card__description {
    display: block;
    max-width: 38rem;
    color: var(--hero-cta-card-muted);
    font-size: clamp(0.9rem, 1vw, 0.98rem);
    line-height: 1.5;
    text-align: left;
  }

  .hero-cta-card__divider {
    display: block;
    width: 100%;
    height: 1px;
    align-self: end;
    margin-top: clamp(0.08rem, 0.45vw, 0.24rem);
    background: linear-gradient(
      90deg,
      color-mix(in oklab, var(--white) 8%, transparent),
      color-mix(in oklab, var(--hero-cta-accent) 24%, transparent),
      color-mix(in oklab, var(--white) 7%, transparent)
    );
    opacity: 0.78;
  }

  .hero-cta-card__link {
    display: inline-flex;
    align-items: center;
    align-self: end;
    justify-self: start;
    gap: 0.58rem;
    margin-top: 0;
    color: color-mix(in oklab, var(--hero-cta-accent) 82%, white 14%);
    font-size: clamp(0.94rem, 1.2vw, 1.04rem);
    font-weight: 760;
    line-height: 1.1;
    text-align: left;
  }

  .hero-cta-card__arrow {
    width: 1.35rem;
    height: 1.35rem;
    transition: transform var(--motion-duration-fast) var(--motion-ease-decelerate);
  }

  .hero-cta-card:hover,
  .hero-cta-card:focus-visible {
    border-color: var(--hero-cta-card-border-active);
    box-shadow:
      0 28px 78px -43px var(--hero-cta-glow),
      0 18px 42px -32px rgba(0, 0, 0, 0.92),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transform: translateY(-0.16rem);
  }

  .hero-cta-card:hover::before,
  .hero-cta-card:focus-visible::before {
    opacity: 1;
  }

  .hero-cta-card:hover .hero-cta-card__icon-shell,
  .hero-cta-card:focus-visible .hero-cta-card__icon-shell {
    border-color: color-mix(in oklab, var(--hero-cta-accent) 54%, rgba(255, 255, 255, 0.18));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 0 2rem -0.44rem var(--hero-cta-glow);
    transform: translate3d(0.06rem, -0.12rem, 0) rotate(-2deg) scale(1.028);
  }

  .hero-cta-card:hover .hero-cta-card__icon,
  .hero-cta-card:focus-visible .hero-cta-card__icon {
    transform: translate3d(0.03rem, -0.02rem, 0) rotate(4deg) scale(1.045);
  }

  .hero-cta-card:hover .hero-cta-card__arrow,
  .hero-cta-card:focus-visible .hero-cta-card__arrow {
    transform: translateX(0.22rem);
  }

  .hero-cta-card:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--hero-cta-accent) 76%, white 10%);
    outline-offset: 0.22rem;
  }

  @media (min-width: 1024px) {
    .hero-cta-card {
      min-height: 11.2rem;
    }
  }

  @media (max-width: 767px) {
    .hero-cta-card {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto minmax(0, 1fr) auto auto;
      min-height: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta-card,
    .hero-cta-card::before,
    .hero-cta-card__icon-shell,
    .hero-cta-card__icon,
    .hero-cta-card__arrow {
      transition: none;
    }

    .hero-cta-card:hover,
    .hero-cta-card:focus-visible,
    .hero-cta-card:hover .hero-cta-card__icon-shell,
    .hero-cta-card:focus-visible .hero-cta-card__icon-shell,
    .hero-cta-card:hover .hero-cta-card__icon,
    .hero-cta-card:focus-visible .hero-cta-card__icon,
    .hero-cta-card:hover .hero-cta-card__arrow,
    .hero-cta-card:focus-visible .hero-cta-card__arrow {
      transform: none;
    }
  }
</style>
