---
import { galaxyComets, galaxyStars } from '@/components/sections/hero/hero-data';
---

<div class="hero-galaxy" aria-hidden="true">
  <span class="hero-galaxy__nebula hero-galaxy__nebula--core"></span>
  <span class="hero-galaxy__nebula hero-galaxy__nebula--cyan"></span>
  <span class="hero-galaxy__nebula hero-galaxy__nebula--violet"></span>
  <span class="hero-galaxy__orbit hero-galaxy__orbit--primary"></span>
  <span class="hero-galaxy__orbit hero-galaxy__orbit--secondary"></span>
  <span class="hero-galaxy__orbit hero-galaxy__orbit--tertiary"></span>
  {galaxyStars.map(({ className, style }) => <span class={className} style={style} />)}
  {galaxyComets.map(({ className, style }) => <span class={className} style={style} />)}
</div>

<style>
  .hero-galaxy {
    position: absolute;
    inset: -4.4rem;
    pointer-events: none;
    z-index: -1;
    border-radius: 999px;
    opacity: 0.95;
    transform: translateZ(0);
    animation: hero-galaxy-enter 900ms var(--motion-ease-decelerate) 90ms backwards;
  }

  .hero-galaxy__nebula,
  .hero-galaxy__orbit,
  .hero-galaxy__star,
  .hero-galaxy__comet {
    position: absolute;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero-galaxy__nebula {
    border-radius: 999px;
    filter: blur(var(--blur, 20px)) saturate(128%);
    opacity: var(--opacity, 0.55);
    transition:
      opacity 420ms var(--motion-ease-decelerate),
      transform 520ms var(--motion-ease-decelerate),
      filter 520ms var(--motion-ease-decelerate);
    animation: hero-nebula-enter 920ms var(--motion-ease-decelerate) backwards;
  }

  .hero-galaxy__nebula--core {
    inset: 11%;
    --blur: 22px;
    --opacity: 0.5;
    animation-delay: 90ms;
    background:
      radial-gradient(circle at 52% 42%, rgba(125, 211, 252, 0.18), transparent 34%),
      radial-gradient(circle at 34% 61%, rgba(96, 165, 250, 0.28), transparent 50%),
      radial-gradient(circle at 70% 36%, rgba(124, 58, 237, 0.22), transparent 48%);
  }

  .hero-galaxy__nebula--cyan {
    top: 12%;
    left: -10%;
    width: 54%;
    aspect-ratio: 1;
    --blur: 24px;
    --opacity: 0.42;
    animation-delay: 180ms;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.48), transparent 64%);
  }

  .hero-galaxy__nebula--violet {
    right: -13%;
    bottom: 2%;
    width: 58%;
    aspect-ratio: 1;
    --blur: 28px;
    --opacity: 0.38;
    animation-delay: 230ms;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.44), transparent 66%);
  }

  .hero-galaxy__orbit {
    top: 50%;
    left: 50%;
    aspect-ratio: 1;
    border-radius: 999px;
    border: 1px solid rgba(147, 197, 253, 0.2);
    --hero-orbit-mask: conic-gradient(
      from 22deg,
      transparent 0deg,
      #000 28deg,
      #000 242deg,
      rgba(0, 0, 0, 0.3) 286deg,
      transparent 326deg,
      transparent 360deg
    );
    box-shadow:
      inset 0 0 18px rgba(56, 189, 248, 0.06),
      0 0 26px rgba(59, 130, 246, 0.1);
    -webkit-mask-image: var(--hero-orbit-mask);
    mask-image: var(--hero-orbit-mask);
    transform: translate(-50%, -50%) rotate(var(--rotate, 0deg));
    transition:
      border-color 360ms ease,
      box-shadow 360ms ease,
      opacity 360ms ease,
      transform 720ms var(--motion-ease-decelerate);
    animation: hero-orbit-enter 980ms var(--motion-ease-decelerate) backwards;
  }

  .hero-galaxy__orbit--primary {
    width: 102%;
    --rotate: -8deg;
    --orbit-opacity: 0.7;
    opacity: var(--orbit-opacity);
    animation-delay: 160ms;
  }

  .hero-galaxy__orbit--secondary {
    width: 126%;
    --rotate: 24deg;
    --orbit-opacity: 0.42;
    border-color: rgba(45, 212, 191, 0.2);
    border-style: dashed;
    --hero-orbit-mask: conic-gradient(
      from -42deg,
      rgba(0, 0, 0, 0.16) 0deg,
      #000 38deg,
      #000 178deg,
      rgba(0, 0, 0, 0.22) 236deg,
      transparent 300deg,
      rgba(0, 0, 0, 0.12) 360deg
    );
    opacity: var(--orbit-opacity);
    animation-delay: 240ms;
  }

  .hero-galaxy__orbit--tertiary {
    width: 152%;
    --rotate: -38deg;
    --orbit-opacity: 0.28;
    border-color: rgba(196, 181, 253, 0.22);
    border-style: dashed;
    --hero-orbit-mask: conic-gradient(
      from 112deg,
      transparent 0deg,
      rgba(0, 0, 0, 0.28) 48deg,
      #000 118deg,
      #000 196deg,
      rgba(0, 0, 0, 0.2) 258deg,
      transparent 328deg,
      transparent 360deg
    );
    opacity: var(--orbit-opacity);
    animation-delay: 320ms;
  }

  .hero-galaxy__star {
    top: var(--y);
    left: var(--x);
    width: var(--size, 0.22rem);
    height: var(--size, 0.22rem);
    border-radius: 999px;
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.98),
      rgba(125, 211, 252, 0.85) 42%,
      transparent 72%
    );
    opacity: 0.7;
    box-shadow:
      0 0 10px rgba(125, 211, 252, 0.55),
      0 0 18px rgba(59, 130, 246, 0.3);
    translate: -50% -50%;
    transform: scale(1);
    transition:
      opacity 280ms ease var(--delay, 0ms),
      transform 620ms var(--motion-ease-decelerate) var(--delay, 0ms),
      filter 320ms ease var(--delay, 0ms);
    animation:
      hero-star-enter 760ms var(--motion-ease-decelerate) calc(var(--delay, 0ms) + 380ms) backwards,
      hero-star-orbit-drift var(--orbit-duration, 12s) ease-in-out calc(var(--delay, 0ms) + 1.2s)
        infinite alternate;
  }

  .hero-galaxy__star--warm {
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.98),
      rgba(251, 191, 36, 0.84) 44%,
      transparent 72%
    );
    box-shadow:
      0 0 10px rgba(251, 191, 36, 0.42),
      0 0 18px rgba(251, 146, 60, 0.22);
  }

  .hero-galaxy__comet {
    width: 4.25rem;
    height: 0.14rem;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(226, 246, 255, 0.95), transparent);
    filter: blur(0.2px) drop-shadow(0 0 8px rgba(125, 211, 252, 0.65));
    opacity: 0;
    transform-origin: center;
    animation: hero-comet-enter 860ms var(--motion-ease-decelerate) calc(var(--delay, 0ms) + 520ms)
      backwards;
  }

  .hero-galaxy__comet--north {
    top: 18%;
    left: 64%;
    transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.45);
  }

  .hero-galaxy__comet--south {
    right: 68%;
    bottom: 12%;
    transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.42);
    background: linear-gradient(90deg, transparent, rgba(221, 214, 254, 0.9), transparent);
  }

  :global(.hero-avatar:hover) .hero-galaxy__nebula,
  :global(.hero-avatar:focus-within) .hero-galaxy__nebula {
    opacity: calc(var(--opacity, 0.55) + 0.18);
    filter: blur(calc(var(--blur, 20px) + 2px)) saturate(148%);
  }

  :global(.hero-avatar:hover) .hero-galaxy__nebula--core,
  :global(.hero-avatar:focus-within) .hero-galaxy__nebula--core {
    transform: scale(1.08) rotate(7deg);
  }

  :global(.hero-avatar:hover) .hero-galaxy__nebula--cyan,
  :global(.hero-avatar:focus-within) .hero-galaxy__nebula--cyan {
    transform: translate3d(-0.35rem, -0.45rem, 0) scale(1.12);
  }

  :global(.hero-avatar:hover) .hero-galaxy__nebula--violet,
  :global(.hero-avatar:focus-within) .hero-galaxy__nebula--violet {
    transform: translate3d(0.4rem, 0.5rem, 0) scale(1.1);
  }

  :global(.hero-avatar:hover) .hero-galaxy__orbit,
  :global(.hero-avatar:focus-within) .hero-galaxy__orbit {
    border-color: rgba(191, 219, 254, 0.44);
    box-shadow:
      inset 0 0 24px rgba(125, 211, 252, 0.14),
      0 0 34px rgba(59, 130, 246, 0.18);
    opacity: 0.95;
  }

  :global(.hero-avatar:hover) .hero-galaxy__orbit--primary,
  :global(.hero-avatar:focus-within) .hero-galaxy__orbit--primary {
    transform: translate(-50%, -50%) rotate(18deg) scale(1.04);
  }

  :global(.hero-avatar:hover) .hero-galaxy__orbit--secondary,
  :global(.hero-avatar:focus-within) .hero-galaxy__orbit--secondary {
    transform: translate(-50%, -50%) rotate(-18deg) scale(1.03);
  }

  :global(.hero-avatar:hover) .hero-galaxy__orbit--tertiary,
  :global(.hero-avatar:focus-within) .hero-galaxy__orbit--tertiary {
    transform: translate(-50%, -50%) rotate(34deg) scale(1.02);
  }

  :global(.hero-avatar:hover) .hero-galaxy__star,
  :global(.hero-avatar:focus-within) .hero-galaxy__star {
    opacity: 1;
    filter: saturate(150%);
    animation-play-state: paused;
    transform: scale(1.45);
  }

  :global(.hero-avatar:hover) .hero-galaxy__comet,
  :global(.hero-avatar:focus-within) .hero-galaxy__comet {
    animation: hero-comet-sweep 880ms var(--motion-ease-decelerate) var(--delay, 0ms) both;
  }

  @keyframes hero-galaxy-enter {
    0% {
      opacity: 0;
      transform: translate3d(0, 0.7rem, 0) scale(0.88);
      filter: saturate(70%);
    }
    100% {
      opacity: 1;
      transform: translateZ(0) scale(1);
      filter: saturate(100%);
    }
  }

  @keyframes hero-nebula-enter {
    0% {
      opacity: 0;
      transform: scale(0.72);
      filter: blur(calc(var(--blur, 20px) + 10px)) saturate(70%);
    }
    100% {
      opacity: var(--opacity, 0.55);
      transform: scale(1);
      filter: blur(var(--blur, 20px)) saturate(128%);
    }
  }

  @keyframes hero-orbit-enter {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) rotate(calc(var(--rotate, 0deg) - 22deg)) scale(0.72);
    }
    68% {
      opacity: 1;
    }
    100% {
      opacity: var(--orbit-opacity, 0.8);
      transform: translate(-50%, -50%) rotate(var(--rotate, 0deg)) scale(1);
    }
  }

  @keyframes hero-star-enter {
    0% {
      opacity: 0;
      transform: scale(0.18);
      filter: blur(2px) saturate(70%);
    }
    55% {
      opacity: 1;
      transform: scale(1.7);
      filter: blur(0) saturate(140%);
    }
    100% {
      opacity: 0.7;
      transform: scale(1);
      filter: blur(0) saturate(100%);
    }
  }

  @keyframes hero-star-orbit-drift {
    0%,
    100% {
      translate: -50% -50%;
    }
    42% {
      translate: calc(-50% + calc(var(--drift-x, 0rem) * 0.26))
        calc(-50% + calc(var(--drift-y, 0rem) * 0.26));
    }
    72% {
      translate: calc(-50% - calc(var(--drift-y, 0rem) * 0.16))
        calc(-50% + calc(var(--drift-x, 0rem) * 0.18));
    }
  }

  @keyframes hero-comet-enter {
    0% {
      opacity: 0;
      transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.18);
    }
    42% {
      opacity: 0.72;
    }
    100% {
      opacity: 0;
      transform: translate3d(var(--end-x), var(--end-y), 0) rotate(var(--angle)) scaleX(0.82);
    }
  }

  @keyframes hero-comet-sweep {
    0% {
      opacity: 0;
      transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.32);
    }
    34% {
      opacity: 0.9;
    }
    100% {
      opacity: 0;
      transform: translate3d(var(--end-x), var(--end-y), 0) rotate(var(--angle)) scaleX(1.05);
    }
  }

  @media (min-width: 768px) {
    .hero-galaxy {
      inset: -5.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-galaxy,
    .hero-galaxy__nebula,
    .hero-galaxy__orbit,
    .hero-galaxy__star,
    .hero-galaxy__comet {
      animation: none;
      transition: none;
    }

    :global(.hero-avatar:hover) .hero-galaxy__comet,
    :global(.hero-avatar:focus-within) .hero-galaxy__comet {
      animation: none;
      opacity: 0;
    }

    :global(.hero-avatar:hover) .hero-galaxy__nebula,
    :global(.hero-avatar:focus-within) .hero-galaxy__nebula {
      transform: none;
    }

    :global(.hero-avatar:hover) .hero-galaxy__orbit--primary,
    :global(.hero-avatar:focus-within) .hero-galaxy__orbit--primary {
      transform: translate(-50%, -50%) rotate(-8deg);
    }

    :global(.hero-avatar:hover) .hero-galaxy__orbit--secondary,
    :global(.hero-avatar:focus-within) .hero-galaxy__orbit--secondary {
      transform: translate(-50%, -50%) rotate(24deg);
    }

    :global(.hero-avatar:hover) .hero-galaxy__orbit--tertiary,
    :global(.hero-avatar:focus-within) .hero-galaxy__orbit--tertiary {
      transform: translate(-50%, -50%) rotate(-38deg);
    }

    :global(.hero-avatar:hover) .hero-galaxy__star,
    :global(.hero-avatar:focus-within) .hero-galaxy__star {
      translate: -50% -50%;
      transform: scale(1);
    }
  }
</style>
