---
import Container from '@/components/ui/core/Container.astro';
import GlassButton from '@/components/ui/navigation/GlassButton';
import { Image } from 'astro:assets';
import { Activity, BookOpen, BrainCircuit, ChartColumn, Mic, Network, Rocket } from '@lucide/astro';
import profileImage from '@/assets/images/profile.jpg';
import type { SiteCopy } from '@/data/site/copy';

interface Props {
  copy: SiteCopy['home']['hero'];
}

const { copy } = Astro.props as Props;

const iconMap = {
  rocket: Rocket,
  'book-open': BookOpen,
  mic: Mic,
} as const;

const topicIconMap = {
  brain: BrainCircuit,
  activity: Activity,
  'bar-chart-3': ChartColumn,
  network: Network,
} as const;

const ctaItems = copy.primaryCtas.map(config => ({
  ...config,
  Icon: iconMap[config.icon],
}));

const topicItems = copy.topics.map(config => ({
  ...config,
  Icon: topicIconMap[config.icon],
}));

const orbitAspects = [
  {
    label: 'Research',
    detail: 'Behavior, reasoning, and evaluation',
    tone: 'cyan',
    style:
      '--x: 14%; --y: 24%; --label-x: -6%; --label-y: -112%; --twinkle-delay: 80ms; --twinkle-duration: 3.8s; --glint-delay: 340ms;',
  },
  {
    label: 'Engineering',
    detail: 'Systems, tooling, and deployment paths',
    tone: 'amber',
    style:
      '--x: 86%; --y: 34%; --label-x: -76%; --label-y: -116%; --twinkle-delay: 860ms; --twinkle-duration: 4.4s; --glint-delay: 1220ms;',
  },
  {
    label: 'Design',
    detail: 'Readable interfaces for complex AI behavior',
    tone: 'violet',
    style:
      '--x: 8%; --y: 62%; --label-x: 10%; --label-y: 36%; --twinkle-delay: 1460ms; --twinkle-duration: 4.1s; --glint-delay: 1860ms;',
  },
] as const;

const displayName = 'Pittawat Taveekitworachai';
const [givenName = displayName, ...familyNameParts] = displayName.split(' ');
const familyName = familyNameParts.join(' ');

const englishIntro = 'I study how language models acquire and express behavior.';
const thaiIntro = 'ผมศึกษาว่าโมเดลภาษาเรียนรู้และแสดงพฤติกรรมออกมาอย่างไร';
const introVariant = copy.intro === englishIntro ? 'en' : copy.intro === thaiIntro ? 'th' : 'plain';
---

<Container
  className="relative -mt-2 flex flex-col items-center justify-center gap-9 md:-mt-4 md:grid md:grid-cols-[minmax(0,1.12fr)_minmax(18rem,0.88fr)] md:items-start md:gap-10"
>
  <div class="hero-copy order-1 md:col-span-1">
    <div class="hero-copy__inner">
      <div class="hero-statement">
        <h1 class="hero-name">
          <span class="hero-name__given">{givenName}</span>
          {familyName && <span class="hero-name__family">{familyName}</span>}
        </h1>

        <p class="hero-lead">
          {
            introVariant === 'en' ? (
              <>
                I study how language models <span>acquire</span>
                <br class="hidden sm:block" /> and <span>express behavior</span>.
              </>
            ) : introVariant === 'th' ? (
              <>
                ผมศึกษาว่าโมเดลภาษา<span>เรียนรู้</span>
                <br class="hidden sm:block" /> และ<span>แสดงพฤติกรรม</span>ออกมาอย่างไร
              </>
            ) : (
              copy.intro
            )
          }
        </p>

        <p class="hero-summary">{copy.summary}</p>
      </div>

      <div class="hero-topic-list" aria-label="Research focus areas">
        {
          topicItems.map(({ label, Icon }) => (
            <span class="hero-topic">
              <Icon class="hero-topic__icon" aria-hidden="true" />
              <span>{label}</span>
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="relative order-2 flex w-full max-w-[21rem] flex-col items-center md:ml-auto md:justify-self-center"
  >
    <div
      class="hero-avatar group relative mx-auto w-full max-w-[15rem] overflow-visible md:mx-0 md:max-w-[20rem]"
    >
      <div class="hero-galaxy" aria-hidden="true">
        <span class="hero-galaxy__nebula hero-galaxy__nebula--core"></span>
        <span class="hero-galaxy__nebula hero-galaxy__nebula--cyan"></span>
        <span class="hero-galaxy__nebula hero-galaxy__nebula--violet"></span>
        <span class="hero-galaxy__orbit hero-galaxy__orbit--primary"></span>
        <span class="hero-galaxy__orbit hero-galaxy__orbit--secondary"></span>
        <span class="hero-galaxy__orbit hero-galaxy__orbit--tertiary"></span>
        <span
          class="hero-galaxy__star"
          style="--x: 10%; --y: 28%; --size: 0.22rem; --delay: 30ms; --drift-x: -0.8rem; --drift-y: -0.9rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 20%; --y: 9%; --size: 0.34rem; --delay: 90ms; --drift-x: -0.35rem; --drift-y: -1.15rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 45%; --y: 2%; --size: 0.18rem; --delay: 140ms; --drift-x: 0rem; --drift-y: -1.2rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 77%; --y: 13%; --size: 0.26rem; --delay: 60ms; --drift-x: 0.8rem; --drift-y: -0.95rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 92%; --y: 39%; --size: 0.2rem; --delay: 170ms; --drift-x: 1.1rem; --drift-y: -0.25rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 84%; --y: 70%; --size: 0.32rem; --delay: 120ms; --drift-x: 0.95rem; --drift-y: 0.85rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 61%; --y: 93%; --size: 0.2rem; --delay: 220ms; --drift-x: 0.35rem; --drift-y: 1.2rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 28%; --y: 88%; --size: 0.26rem; --delay: 160ms; --drift-x: -0.65rem; --drift-y: 1rem;"
        ></span>
        <span
          class="hero-galaxy__star"
          style="--x: 4%; --y: 61%; --size: 0.18rem; --delay: 200ms; --drift-x: -1.05rem; --drift-y: 0.42rem;"
        ></span>
        <span
          class="hero-galaxy__star hero-galaxy__star--warm"
          style="--x: 17%; --y: 72%; --size: 0.24rem; --delay: 260ms; --drift-x: -0.9rem; --drift-y: 0.9rem;"
        ></span>
        <span
          class="hero-galaxy__star hero-galaxy__star--warm"
          style="--x: 87%; --y: 52%; --size: 0.16rem; --delay: 240ms; --drift-x: 1.15rem; --drift-y: 0.15rem;"
        ></span>
        <span
          class="hero-galaxy__comet hero-galaxy__comet--north"
          style="--delay: 60ms; --angle: -24deg; --start-x: -1.7rem; --start-y: 0.2rem; --end-x: 1.5rem; --end-y: -0.55rem;"
        ></span>
        <span
          class="hero-galaxy__comet hero-galaxy__comet--south"
          style="--delay: 180ms; --angle: 152deg; --start-x: 1.5rem; --start-y: -0.2rem; --end-x: -1.4rem; --end-y: 0.5rem;"
        ></span>
      </div>
      <div class="hero-aspects" aria-label="Research, engineering, and design orbit">
        {
          orbitAspects.map(({ label, detail, tone, style }) => (
            <span
              class={`hero-aspect-star hero-aspect-star--${tone}`}
              style={style}
              tabindex="0"
              aria-label={`${label}: ${detail}`}
            >
              <span class="hero-aspect-star__spark" aria-hidden="true" />
              <span class="hero-aspect-star__label">
                <span>{label}</span>
                <small>{detail}</small>
              </span>
            </span>
          ))
        }
      </div>
      <Image
        src={profileImage}
        alt="Pete's profile picture"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        widths={[192, 224, 384, 448]}
        sizes="(min-width: 768px) 18rem, 12rem"
        class="hero-avatar__image avatar-round no-cv relative mx-auto w-full max-w-[15rem] object-cover shadow-lg ring-4 ring-[color:var(--white)]/15 transition-all duration-300 ease-out will-change-transform group-hover:ring-[color:var(--accent)]/60 md:mx-0 md:max-w-[20rem]"
      />
      <div
        class="hero-focus-card shape-squircle absolute -bottom-12 left-1/2 w-full max-w-[18rem] -translate-x-1/2 rounded-3xl border border-white/10 bg-[color:var(--black-nav)]/75 px-5 py-4 text-left shadow-xl shadow-black/30 backdrop-blur-md sm:px-6 sm:py-5 md:-bottom-16 md:max-w-[20rem]"
      >
        <p class="text-xs font-semibold tracking-[0.25em] text-[color:var(--white)]/60 uppercase">
          {copy.focusLabel}
        </p>
        <p class="mt-1.5 text-sm text-[color:var(--white)]/85">
          {copy.focusBody}
        </p>
      </div>
    </div>
  </div>

  <div
    class="shape-squircle order-3 mt-8 grid w-full gap-3 rounded-3xl border border-white/10 bg-white/5 p-4 text-left shadow-lg shadow-black/20 backdrop-blur-sm sm:gap-4 md:col-span-2 md:mt-0 md:grid-cols-3 md:p-6"
  >
    {
      ctaItems.map(({ href, title, description, ctaLabel, variant, Icon }) => (
        <div class="shape-squircle group flex h-full flex-col gap-3 rounded-2xl border border-white/10 bg-[color:var(--black-nav)]/45 p-4 transition-transform duration-200 ease-out hover:-translate-y-1 hover:border-[color:var(--accent)]/30 hover:bg-[color:var(--black-nav)]/65 sm:gap-4 sm:p-5">
          <div class="flex items-start gap-3">
            <div class="flex aspect-square h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[color:var(--accent)] shadow-inner shadow-black/10">
              <Icon class="h-5 w-5" aria-hidden="true" />
            </div>
            <div class="space-y-1.5 sm:space-y-2">
              <p class="text-xs font-semibold tracking-[0.2em] text-[color:var(--white)]/58 uppercase sm:tracking-[0.3em]">
                {title}
              </p>
              <p class="text-sm text-[color:var(--white)]/70">{description}</p>
            </div>
          </div>
          <GlassButton
            href={href}
            variant={variant}
            size="lg"
            icon="arrow-right"
            className="mt-auto w-full justify-between px-5 py-2.5 text-sm sm:px-6 sm:text-base md:px-5 md:py-2.5 md:text-sm lg:px-6 lg:py-3 lg:text-base"
          >
            {ctaLabel}
          </GlassButton>
        </div>
      ))
    }
  </div>
</Container>

<style>
  .hero-copy {
    width: 100%;
    max-width: 42rem;
    text-align: center;
  }

  .hero-copy__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.35rem;
  }

  .hero-statement {
    display: flex;
    flex-direction: column;
    gap: 1.08rem;
  }

  .hero-name {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    margin: 0;
    font-weight: 800;
    line-height: 0.98;
  }

  .hero-name__given,
  .hero-name__family {
    display: block;
  }

  .hero-name__given {
    color: #facc63;
    font-size: 3.4rem;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.14),
      0 18px 42px rgba(250, 204, 99, 0.18);
  }

  .hero-name__family {
    color: rgba(255, 255, 255, 0.94);
    font-size: 2.62rem;
    text-shadow: 0 18px 46px rgba(148, 163, 184, 0.22);
  }

  .hero-lead {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.35rem;
    line-height: 1.45;
  }

  .hero-lead span {
    color: #60a5fa;
    text-shadow: 0 0 24px rgba(96, 165, 250, 0.34);
  }

  .hero-summary {
    margin: 0;
    max-width: 36rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .hero-topic-list {
    display: grid;
    width: min(100%, 35rem);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .hero-topic {
    display: inline-flex;
    min-height: 3.05rem;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 0.85rem;
    background:
      linear-gradient(180deg, rgba(30, 41, 59, 0.52), rgba(15, 23, 42, 0.42)),
      rgba(255, 255, 255, 0.025);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 14px 30px -26px rgba(96, 165, 250, 0.42);
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.1;
    white-space: nowrap;
  }

  .hero-topic__icon {
    width: 1.18rem;
    height: 1.18rem;
    flex: 0 0 auto;
    color: #60a5fa;
    filter: drop-shadow(0 0 10px rgba(96, 165, 250, 0.35));
  }

  @media (min-width: 640px) {
    .hero-name__given {
      font-size: 3.95rem;
    }

    .hero-name__family {
      font-size: 3.05rem;
    }

    .hero-lead {
      font-size: 1.55rem;
    }
  }

  @media (min-width: 768px) {
    .hero-copy {
      max-width: none;
      text-align: left;
    }

    .hero-copy__inner {
      align-items: flex-start;
      gap: 1.45rem;
    }

    .hero-name__given {
      font-size: 4rem;
    }

    .hero-name__family {
      font-size: 2.95rem;
    }

    .hero-summary {
      max-width: 32rem;
    }

    .hero-topic-list {
      width: min(100%, 34rem);
    }
  }

  @media (min-width: 1024px) {
    .hero-copy__inner {
      gap: 1.5rem;
    }

    .hero-name__given {
      font-size: 4.85rem;
    }

    .hero-name__family {
      font-size: 3.62rem;
    }

    .hero-lead {
      font-size: 1.54rem;
      line-height: 1.38;
    }

    .hero-summary {
      max-width: 29rem;
      font-size: 1rem;
    }

    .hero-topic-list {
      width: 100%;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.7rem;
    }

    .hero-topic {
      min-height: 2.72rem;
      gap: 0.5rem;
      border-radius: 0.78rem;
      font-size: 0.78rem;
    }

    .hero-topic__icon {
      width: 1.05rem;
      height: 1.05rem;
    }
  }

  .hero-avatar {
    isolation: isolate;
  }

  .hero-galaxy {
    position: absolute;
    inset: -3rem;
    pointer-events: none;
    z-index: -1;
    border-radius: 999px;
    transform: translateZ(0);
    animation: hero-galaxy-enter 900ms var(--motion-ease-decelerate) 90ms backwards;
  }

  .hero-galaxy__nebula,
  .hero-galaxy__orbit,
  .hero-galaxy__star,
  .hero-galaxy__comet {
    position: absolute;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero-galaxy__nebula {
    border-radius: 999px;
    filter: blur(var(--blur, 20px)) saturate(128%);
    opacity: var(--opacity, 0.55);
    transition:
      opacity 420ms var(--motion-ease-decelerate),
      transform 520ms var(--motion-ease-decelerate),
      filter 520ms var(--motion-ease-decelerate);
    animation: hero-nebula-enter 920ms var(--motion-ease-decelerate) backwards;
  }

  .hero-galaxy__nebula--core {
    inset: 7%;
    --blur: 18px;
    --opacity: 0.62;
    animation-delay: 90ms;
    background:
      radial-gradient(circle at 52% 42%, rgba(125, 211, 252, 0.24), transparent 34%),
      radial-gradient(circle at 34% 61%, rgba(96, 165, 250, 0.36), transparent 50%),
      radial-gradient(circle at 70% 36%, rgba(124, 58, 237, 0.32), transparent 48%);
  }

  .hero-galaxy__nebula--cyan {
    top: 12%;
    left: -10%;
    width: 54%;
    aspect-ratio: 1;
    --blur: 24px;
    --opacity: 0.58;
    animation-delay: 180ms;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.48), transparent 64%);
  }

  .hero-galaxy__nebula--violet {
    right: -13%;
    bottom: 2%;
    width: 58%;
    aspect-ratio: 1;
    --blur: 28px;
    --opacity: 0.48;
    animation-delay: 230ms;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.44), transparent 66%);
  }

  .hero-galaxy__orbit {
    top: 50%;
    left: 50%;
    aspect-ratio: 1;
    border-radius: 999px;
    border: 1px solid rgba(147, 197, 253, 0.22);
    box-shadow:
      inset 0 0 18px rgba(56, 189, 248, 0.08),
      0 0 24px rgba(59, 130, 246, 0.12);
    transform: translate(-50%, -50%) rotate(var(--rotate, 0deg));
    transition:
      border-color 360ms ease,
      box-shadow 360ms ease,
      opacity 360ms ease,
      transform 720ms var(--motion-ease-decelerate);
    animation: hero-orbit-enter 980ms var(--motion-ease-decelerate) backwards;
  }

  .hero-galaxy__orbit--primary {
    width: 89%;
    --rotate: -8deg;
    --orbit-opacity: 0.8;
    opacity: var(--orbit-opacity);
    animation-delay: 160ms;
  }

  .hero-galaxy__orbit--secondary {
    width: 108%;
    --rotate: 24deg;
    --orbit-opacity: 0.55;
    border-color: rgba(45, 212, 191, 0.2);
    opacity: var(--orbit-opacity);
    animation-delay: 240ms;
  }

  .hero-galaxy__orbit--tertiary {
    width: 124%;
    --rotate: -38deg;
    --orbit-opacity: 0.42;
    border-color: rgba(196, 181, 253, 0.18);
    opacity: var(--orbit-opacity);
    animation-delay: 320ms;
  }

  .hero-galaxy__star {
    top: var(--y);
    left: var(--x);
    width: var(--size, 0.22rem);
    height: var(--size, 0.22rem);
    border-radius: 999px;
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.98),
      rgba(125, 211, 252, 0.85) 42%,
      transparent 72%
    );
    opacity: 0.7;
    box-shadow:
      0 0 10px rgba(125, 211, 252, 0.55),
      0 0 18px rgba(59, 130, 246, 0.3);
    transform: translate(-50%, -50%) scale(1);
    transition:
      opacity 280ms ease var(--delay, 0ms),
      transform 620ms var(--motion-ease-decelerate) var(--delay, 0ms),
      filter 320ms ease var(--delay, 0ms);
    animation: hero-star-enter 760ms var(--motion-ease-decelerate) calc(var(--delay, 0ms) + 380ms)
      backwards;
  }

  .hero-galaxy__star--warm {
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.98),
      rgba(251, 191, 36, 0.84) 44%,
      transparent 72%
    );
    box-shadow:
      0 0 10px rgba(251, 191, 36, 0.42),
      0 0 18px rgba(251, 146, 60, 0.22);
  }

  .hero-galaxy__comet {
    width: 4.25rem;
    height: 0.14rem;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(226, 246, 255, 0.95), transparent);
    filter: blur(0.2px) drop-shadow(0 0 8px rgba(125, 211, 252, 0.65));
    opacity: 0;
    transform-origin: center;
    animation: hero-comet-enter 860ms var(--motion-ease-decelerate) calc(var(--delay, 0ms) + 520ms)
      backwards;
  }

  .hero-galaxy__comet--north {
    top: 18%;
    left: 64%;
    transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.45);
  }

  .hero-galaxy__comet--south {
    right: 68%;
    bottom: 12%;
    transform: translate3d(var(--start-x), var(--start-y), 0) rotate(var(--angle)) scaleX(0.42);
    background: linear-gradient(90deg, transparent, rgba(221, 214, 254, 0.9), transparent);
  }

  @media (min-width: 768px) {
    .hero-galaxy {
      inset: -4rem;
    }
  }

  .hero-aspects {
    position: absolute;
    inset: -2.55rem;
    z-index: 3;
    pointer-events: none;
    border-radius: 999px;
    animation: hero-aspects-enter 780ms var(--motion-ease-decelerate) 520ms backwards;
  }

  .hero-aspect-star {
    position: absolute;
    top: var(--y);
    left: var(--x);
    display: grid;
    width: 1.35rem;
    height: 1.35rem;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--star-color, #7dd3fc);
    cursor: default;
    pointer-events: auto;
    transform: translate(-50%, -50%) scale(1);
    transition:
      transform 320ms var(--motion-ease-decelerate),
      filter 320ms ease;
  }

  .hero-aspect-star__spark {
    position: relative;
    display: block;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background:
      radial-gradient(
        circle at 34% 30%,
        rgba(255, 255, 255, 0.98),
        currentColor 42%,
        transparent 72%
      ),
      currentColor;
    box-shadow:
      0 0 0 0.24rem color-mix(in srgb, currentColor 13%, transparent),
      0 0 1rem color-mix(in srgb, currentColor 72%, transparent),
      0 0 2rem color-mix(in srgb, currentColor 38%, transparent);
    animation: hero-aspect-twinkle var(--twinkle-duration, 4s) ease-in-out var(--twinkle-delay, 0ms)
      infinite;
  }

  .hero-aspect-star__spark::before,
  .hero-aspect-star__spark::after {
    position: absolute;
    inset: 50% auto auto 50%;
    content: '';
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.92), transparent);
    opacity: 0.86;
    transform: translate(-50%, -50%);
    transform-origin: center;
  }

  .hero-aspect-star__spark::before {
    width: 1.45rem;
    height: 0.08rem;
    animation: hero-aspect-glint 5.6s ease-in-out var(--glint-delay, 0ms) infinite;
  }

  .hero-aspect-star__spark::after {
    width: 0.08rem;
    height: 1.45rem;
    animation: hero-aspect-glint 5.6s ease-in-out calc(var(--glint-delay, 0ms) + 180ms) infinite;
  }

