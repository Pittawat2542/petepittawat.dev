---
import Container from '@/components/ui/core/Container.astro';
import HeroCtaGrid from '@/components/sections/HeroCtaGrid.astro';
import HeroIntro from '@/components/sections/hero/HeroIntro.astro';
import HeroPortrait from '@/components/sections/hero/HeroPortrait.astro';
import type { SiteCopy } from '@/data/site/copy';

interface Props {
  copy: SiteCopy['home']['hero'];
  selectedOutput: SiteCopy['home']['selectedOutput'];
  selectedOutputStats: Record<'posts' | 'publications' | 'talks', number>;
}

const { copy, selectedOutput, selectedOutputStats } = Astro.props as Props;
---

<Container
  className="relative -mt-2 flex flex-col items-center justify-center gap-7 md:-mt-4 md:grid md:grid-cols-[minmax(0,0.98fr)_minmax(18rem,1.02fr)] md:items-start md:gap-x-14 md:gap-y-7 lg:gap-x-20 lg:gap-y-8"
>
  <HeroIntro copy={copy} />
  <HeroPortrait />

  <div class="order-3 mt-1 w-full md:col-span-2 md:mt-3 lg:mt-4">
    <HeroCtaGrid heading={copy.ctaHeading} copy={selectedOutput} stats={selectedOutputStats} />
  </div>
</Container>
