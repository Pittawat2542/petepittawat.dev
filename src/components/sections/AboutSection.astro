---
import Container from '@/components/ui/core/Container.astro';
import GlassCard from '@/components/ui/core/GlassCard.astro';
import GlassButton from '@/components/ui/navigation/GlassButton';
import {
  GraduationCap,
  BookOpen,
  ArrowRight,
  Cpu,
  ShieldCheck,
  Activity,
  Globe,
  Layers,
} from '@lucide/astro';
import type { SiteCopy } from '@/data/site/copy';
import AboutHighlightCard from './about/AboutHighlightCard.astro';
import AboutThemeFocusItem from './about/AboutThemeFocusItem.astro';
import AboutThemeSummaryCard from './about/AboutThemeSummaryCard.astro';

interface Props {
  copy: SiteCopy['home']['aboutSection'];
}

const { copy } = Astro.props as Props;

const researchThemeIcons = {
  activity: Activity,
  layers: Layers,
  'shield-check': ShieldCheck,
  globe: Globe,
} as const;

const highlightIcons = {
  'book-open': BookOpen,
  'graduation-cap': GraduationCap,
  cpu: Cpu,
} as const;
---

<Container className="reveal mt-16">
  <GlassCard className="relative overflow-hidden p-0 md:p-0" id="about">
    <div
      aria-hidden="true"
      class="shape-squircle pointer-events-none absolute inset-0 rounded-2xl bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.18),transparent_55%),radial-gradient(circle_at_bottom_right,rgba(236,72,153,0.16),transparent_60%)]"
    >
    </div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div
        class="absolute -top-28 right-[-15%] h-80 w-80 rounded-full bg-gradient-to-br from-[color:var(--accent)]/35 via-transparent to-transparent blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-[-35%] left-[-10%] h-96 w-96 rounded-full bg-gradient-to-t from-[color:var(--accent-publications)]/30 via-transparent to-transparent blur-[180px]"
      >
      </div>
    </div>
    <div
      class="relative z-10 grid gap-12 p-8 md:p-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]"
    >
      <div class="space-y-8">
        <div
          class="flex items-center gap-2 text-xs font-semibold tracking-[0.35em] text-[color:var(--white)]/60 uppercase"
        >
          <span class="h-2 w-2 rounded-full bg-[color:var(--accent)]"></span>
          {copy.eyebrow}
        </div>
        <div class="space-y-4">
          <h2 class="text-3xl font-bold tracking-tight text-[color:var(--white)] md:text-4xl">
            {copy.title}
          </h2>
          <p class="text-lg text-[color:var(--white)]/85">{copy.lead}</p>
          <p class="text-[color:var(--white)]/75">{copy.body}</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            copy.themes.map(theme => {
              const Icon = researchThemeIcons[theme.icon];

              return (
                <AboutThemeSummaryCard
                  title={theme.title}
                  description={theme.description}
                  Icon={Icon}
                />
              );
            })
          }
        </div>

        <GlassButton href="/about" variant="primary" size="md">
          {copy.ctaLabel}
          <ArrowRight class="h-4 w-4" aria-hidden="true" />
        </GlassButton>
      </div>

      <div class="space-y-6 lg:self-start">
        <div
          class="shape-squircle relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-black/20 backdrop-blur-sm"
        >
          <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-70">
            <div
              class="absolute -top-24 right-[-10%] h-48 w-48 rounded-full bg-gradient-to-br from-[color:var(--accent)]/25 via-transparent to-transparent blur-3xl"
            >
            </div>
            <div
              class="absolute bottom-[-35%] left-[-15%] h-60 w-60 rounded-full bg-gradient-to-tr from-[color:var(--accent-publications)]/25 via-transparent to-transparent blur-[140px]"
            >
            </div>
          </div>
          <div class="relative z-10 space-y-5">
            <h3 class="flex items-center gap-2 text-lg font-semibold text-[color:var(--white)]">
              <GraduationCap class="h-5 w-5" aria-hidden="true" />
              {copy.researchFocusTitle}
            </h3>
            <p class="text-sm text-[color:var(--white)]/70">{copy.researchFocusDescription}</p>
            <ul class="space-y-4">
              {
                copy.themes.map(theme => {
                  const Icon = researchThemeIcons[theme.icon];

                  return (
                    <AboutThemeFocusItem
                      title={theme.title}
                      description={theme.description}
                      Icon={Icon}
                    />
                  );
                })
              }
            </ul>
          </div>
        </div>
      </div>
      <div
        class="shape-squircle relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-black/20 backdrop-blur-sm lg:col-span-2"
      >
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-70">
          <div
            class="absolute -top-20 left-[-5%] h-40 w-40 rounded-full bg-gradient-to-br from-[color:var(--accent-talks)]/25 via-transparent to-transparent blur-3xl"
          >
          </div>
          <div
            class="absolute right-[-10%] bottom-[-30%] h-56 w-56 rounded-full bg-gradient-to-tr from-[color:var(--accent-about)]/25 via-transparent to-transparent blur-[140px]"
          >
          </div>
        </div>
        <div class="relative z-10 space-y-5">
          <h3 class="flex items-center gap-2 text-lg font-semibold text-[color:var(--white)]">
            <BookOpen class="h-5 w-5" aria-hidden="true" />
            {copy.highlightsTitle}
          </h3>
          <p class="text-sm text-[color:var(--white)]/70">{copy.highlightsDescription}</p>
          <ul class="grid gap-4 md:grid-cols-3">
            {
              copy.highlights.map(item => {
                const Icon = highlightIcons[item.icon];

                return (
                  <AboutHighlightCard
                    title={item.title}
                    description={item.description}
                    Icon={Icon}
                  />
                );
              })
            }
          </ul>
        </div>
      </div>
    </div>
  </GlassCard>
</Container>
