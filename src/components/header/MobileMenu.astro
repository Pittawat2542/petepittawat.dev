---
import { BookOpenText, FolderKanban, FileText, Mic, CircleUser } from '@lucide/astro';

export interface Props {
  currentPath: string;
  class?: string;
  renderToggle?: boolean;
  renderPanel?: boolean;
}

const { currentPath, renderToggle = true, renderPanel = true } = Astro.props;

const links = [
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/publications', label: 'Publications' },
  { href: '/talks', label: 'Talks' },
  { href: '/about', label: 'About' },
];

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href + '/'));
---

{
  renderToggle && (
    <button
      id="menu-toggle"
      type="button"
      data-open="false"
      class="menu-toggle min-[960px]:hidden"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="menu-toggle__icon" aria-hidden="true">
        <span />
        <span />
        <span />
      </span>
    </button>
  )
}

{
  renderPanel && (
    <div
      id="mobile-menu"
      data-open="false"
      class="min-[960px]:hidden"
      style="top: calc(env(safe-area-inset-top) + var(--nav-height));"
    >
      <div id="mobile-menu-sheet" data-open="false" class="mx-auto w-full">
        <nav class="mobile-menu-panel" aria-label="Mobile primary navigation">
          <ul class="mobile-menu-panel__list">
            {links.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class={`mobile-menu-link ${isActive(href) ? 'mobile-menu-link--active' : ''}`}
                  data-active={isActive(href) ? 'true' : undefined}
                  aria-current={isActive(href) ? 'page' : undefined}
                >
                  <span class="mobile-menu-link__icon" aria-hidden="true">
                    {label === 'Blog' && <BookOpenText class="h-5 w-5" aria-hidden="true" />}
                    {label === 'Projects' && <FolderKanban class="h-5 w-5" aria-hidden="true" />}
                    {label === 'Publications' && <FileText class="h-5 w-5" aria-hidden="true" />}
                    {label === 'Talks' && <Mic class="h-5 w-5" aria-hidden="true" />}
                    {label === 'About' && <CircleUser class="h-5 w-5" aria-hidden="true" />}
                  </span>

                  <span class="mobile-menu-link__label">{label}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  )
}

<style>
  #mobile-menu {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 40;
    display: flex;
    justify-content: center;
    min-height: calc(100dvh - (env(safe-area-inset-top) + var(--nav-height)));
    opacity: 0;
    pointer-events: none;
    border-top: 1px solid var(--nav-border);
    background: var(--nav-bg-scrolled);
    backdrop-filter: blur(var(--nav-blur-scrolled)) saturate(150%);
    -webkit-backdrop-filter: blur(var(--nav-blur-scrolled)) saturate(150%);
    transition:
      opacity var(--motion-duration-normal) var(--motion-ease-standard),
      border-color var(--motion-duration-normal) var(--motion-ease-standard),
      background-color var(--motion-duration-normal) var(--motion-ease-standard),
      backdrop-filter var(--motion-duration-normal) var(--motion-ease-standard);
  }

  #mobile-menu-sheet {
    display: flex;
    width: min(100%, var(--nav-content-max-width));
    min-height: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: clamp(1rem, 4vw, 1.5rem) var(--nav-padding-x) max(env(safe-area-inset-bottom), 1.25rem);
    opacity: 0;
    transform: translateY(-0.35rem);
    transition:
      transform var(--motion-duration-normal) var(--motion-ease-decelerate),
      opacity var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .mobile-menu-panel {
    width: 100%;
  }

  .mobile-menu-panel__list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mobile-menu-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: 100%;
    min-height: 3.85rem;
    border-radius: 0;
    padding: 0 0.15rem;
    color: var(--nav-link-color);
    outline: none;
    transition:
      color var(--motion-duration-fast) var(--motion-ease-standard),
      background-color var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .mobile-menu-link::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 1px;
    background: color-mix(in oklab, var(--white, #f9fafb) 7%, transparent);
  }

  .mobile-menu-panel__list li:first-child .mobile-menu-link::before {
    content: none;
  }

  .mobile-menu-panel__list li:last-child .mobile-menu-link::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 1px;
    background: color-mix(in oklab, var(--white, #f9fafb) 7%, transparent);
  }

  .mobile-menu-link:hover,
  .mobile-menu-link:focus-visible {
    color: var(--nav-link-color-active);
    background: color-mix(in oklab, var(--white, #f9fafb) 3%, transparent);
  }

  .mobile-menu-link__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 1.55rem;
    height: 1.55rem;
    color: currentColor;
    opacity: 0.82;
  }

  .mobile-menu-link__label {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-width: 0;
    font-family: 'Anuphan', sans-serif;
    font-size: 1.02rem;
    line-height: 1;
    font-weight: 560;
    color: currentColor;
  }

  .mobile-menu-link--active {
    color: var(--nav-link-color-active);
  }

  .mobile-menu-link--active::after,
  .mobile-menu-panel__list li:last-child .mobile-menu-link--active::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: var(--nav-active-rule-height);
    background: var(--nav-active-rule);
    border-radius: 999px 999px 0 0;
  }

  .menu-toggle {
    position: relative;
  }

  .menu-toggle__icon {
    position: relative;
    display: inline-flex;
    width: 1.375rem;
    height: 1.125rem;
  }

  .menu-toggle__icon span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 0.3s ease,
      top 0.35s cubic-bezier(0.22, 0.61, 0.36, 1),
      bottom 0.35s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .menu-toggle__icon span:nth-child(1) {
    top: 0;
  }

  .menu-toggle__icon span:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }

  .menu-toggle__icon span:nth-child(3) {
    bottom: 0;
  }

  .menu-toggle[data-open='true'] .menu-toggle__icon span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  .menu-toggle[data-open='true'] .menu-toggle__icon span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.4);
  }

  .menu-toggle[data-open='true'] .menu-toggle__icon span:nth-child(3) {
    top: 50%;
    bottom: auto;
    transform: translateY(-50%) rotate(-45deg);
  }

  #mobile-menu[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
  }

  #mobile-menu-sheet[data-open='true'] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-menu,
    #mobile-menu-sheet,
    .mobile-menu-link {
      transition: none !important;
    }

    .menu-toggle__icon span,
    .menu-toggle[data-open='true'] .menu-toggle__icon span {
      transition-duration: 0s;
      transform: none !important;
      opacity: 1 !important;
    }

    #mobile-menu-sheet {
      transform: none !important;
    }
  }
</style>
