---
import { SITE_TITLE } from '@/consts';

export interface Props {
  showTitle?: boolean;
  class?: string;
}

const { showTitle = true, class: className } = Astro.props;
---

<a
  href="/"
  aria-label="Go to homepage"
  class:list={[
    'site-logo-link shape-squircle-sm relative inline-flex items-center gap-3 rounded-[1.2rem] px-2 py-1 text-white transition-colors hover:text-white/90 focus-visible:ring-2 focus-visible:ring-[color:var(--accent,#6AC1FF)]/60 focus-visible:outline-none',
    className,
  ]}
>
  <span class="site-logo" aria-hidden="true">
    <span class="site-logo__glow"></span>
    <span class="site-logo__field"></span>
    <span class="site-logo__halo"></span>
    <span class="site-logo__trail"></span>
    <span class="site-logo__flare"></span>
    <span class="site-logo__orbit"></span>
    <span class="site-logo__mark">
      <svg class="h-full w-full text-white" viewBox="0 0 512 512" fill="none" aria-hidden="true">
        <path
          fill="currentColor"
          d="M114 188h150v110c0 24-6 42-18 55s-28 19-48 19c-20 0-35-6-48-19-12-13-18-31-18-55v-57h-18v-53Zm64 53v57c0 10 2 18 6 22 4 5 9 7 16 7h12c7 0 12-2 16-7s6-12 6-22v-57h-56Zm123-53h152v110c0 24-6 42-18 55-12 13-28 19-48 19s-36-6-48-19c-12-13-18-31-18-55v-57h-18v-53Zm64 53v57c0 10 2 18 6 22s9 7 16 7h12c7 0 12-2 16-7 4-4 6-12 6-22v-57h-56Z"
        ></path>
      </svg>
    </span>
    <span class="site-logo__spark site-logo__spark--north"></span>
    <span class="site-logo__spark site-logo__spark--east"></span>
    <span class="site-logo__spark site-logo__spark--south"></span>
  </span>
  {
    showTitle && (
      <span class="hidden text-sm font-medium tracking-tight text-white lg:block lg:text-base">
        {SITE_TITLE}
      </span>
    )
  }
</a>

<style>
  .site-logo-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    contain: layout paint style;
    will-change: transform;
    transition:
      color 220ms ease,
      transform 220ms ease,
      background-color 220ms ease;
    --logo-accent: var(--accent, #6ac1ff);
  }

  .site-logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 1rem;
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--logo-accent) 28%, rgba(255, 255, 255, 0.18)),
      rgba(10, 19, 36, 0.94)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      0 14px 28px -20px rgba(8, 18, 36, 0.8);
    overflow: visible;
    isolation: isolate;
    transform-style: preserve-3d;
    transition:
      transform 240ms ease,
      background 240ms ease,
      box-shadow 240ms ease;
  }

  .site-logo__glow {
    position: absolute;
    inset: -30%;
    border-radius: inherit;
    background:
      radial-gradient(circle at 28% 20%, rgba(255, 255, 255, 0.55), transparent 58%),
      radial-gradient(
        circle at 78% 76%,
        color-mix(in oklab, var(--logo-accent) 32%, rgba(255, 255, 255, 0.2)),
        transparent 62%
      );
    filter: blur(18px);
    opacity: 0.42;
    z-index: 0;
    will-change: opacity, transform;
  }

  .site-logo__field {
    position: absolute;
    inset: -32%;
    border-radius: inherit;
    mix-blend-mode: screen;
    filter: blur(28px);
    opacity: 0.22;
    z-index: 1;
    pointer-events: none;
    will-change: opacity, transform;
  }

  .site-logo__halo {
    position: absolute;
    inset: -7px;
    border-radius: inherit;
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    opacity: 0.34;
    z-index: 2;
    mix-blend-mode: screen;
    will-change: opacity, transform;
  }

  .site-logo__trail {
    position: absolute;
    inset: -10%;
    border-radius: inherit;
    border: 1.5px solid color-mix(in oklab, var(--logo-accent) 55%, rgba(255, 255, 255, 0.35));
    opacity: 0.1;
    filter: blur(1px);
    z-index: 2;
    pointer-events: none;
    will-change: opacity, transform;
  }

  .site-logo__flare {
    position: absolute;
    inset: -15%;
    border-radius: inherit;
    background: conic-gradient(
      from 120deg,
      transparent 0deg,
      color-mix(in oklab, var(--logo-accent) 30%, rgba(255, 255, 255, 0.24)) 120deg,
      transparent 240deg
    );
    opacity: 0.08;
    z-index: 2;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .site-logo__orbit {
    position: absolute;
    inset: -18%;
    border-radius: inherit;
    border: 1px dashed color-mix(in oklab, var(--logo-accent) 48%, rgba(255, 255, 255, 0.22));
    opacity: 0;
    transform: scale(0.9) rotate(-14deg);
    z-index: 2;
    pointer-events: none;
  }

  .site-logo__mark {
    position: relative;
    z-index: 3;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 0.6rem;
  }

  .site-logo__spark {
    position: absolute;
    width: 0.36rem;
    height: 0.36rem;
    border-radius: 999px;
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.98), transparent 72%);
    opacity: 0;
    z-index: 3;
    pointer-events: none;
    filter: blur(0.4px);
  }

  .site-logo__spark--north {
    top: -0.15rem;
    left: 48%;
  }

  .site-logo__spark--east {
    top: 45%;
    right: -0.2rem;
  }

  .site-logo__spark--south {
    right: 16%;
    bottom: -0.1rem;
  }

  .site-logo-link:hover .site-logo,
  .site-logo-link:focus-visible .site-logo {
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--logo-accent) 40%, rgba(255, 255, 255, 0.24)),
      rgba(12, 22, 42, 0.9)
    );
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      0 20px 36px -24px color-mix(in oklab, var(--logo-accent) 24%, rgba(9, 18, 34, 0.9));
  }

  .site-logo-link:hover .site-logo__orbit,
  .site-logo-link:focus-visible .site-logo__orbit {
    animation: site-logo-orbit 1.45s cubic-bezier(0.2, 0.7, 0.2, 1) 180ms both;
  }

  .site-logo-link:hover .site-logo__spark--north,
  .site-logo-link:focus-visible .site-logo__spark--north {
    animation: site-logo-spark-north 1s cubic-bezier(0.18, 0.7, 0.28, 1) 220ms both;
  }

  .site-logo-link:hover .site-logo__spark--east,
  .site-logo-link:focus-visible .site-logo__spark--east {
    animation: site-logo-spark-east 0.95s cubic-bezier(0.18, 0.7, 0.28, 1) 290ms both;
  }

  .site-logo-link:hover .site-logo__spark--south,
  .site-logo-link:focus-visible .site-logo__spark--south {
    animation: site-logo-spark-south 1.05s cubic-bezier(0.18, 0.7, 0.28, 1) 340ms both;
  }

  @keyframes site-logo-orbit {
    0% {
      opacity: 0;
      transform: scale(0.9) rotate(-20deg);
    }
    30% {
      opacity: 0.6;
    }
    100% {
      opacity: 0;
      transform: scale(1.08) rotate(24deg);
    }
  }

  @keyframes site-logo-spark-north {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.4);
    }
    25% {
      opacity: 0.95;
    }
    100% {
      opacity: 0;
      transform: translate3d(-0.2rem, -0.95rem, 0) scale(1.15);
    }
  }

  @keyframes site-logo-spark-east {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.4);
    }
    25% {
      opacity: 0.95;
    }
    100% {
      opacity: 0;
      transform: translate3d(0.95rem, -0.25rem, 0) scale(1.1);
    }
  }

  @keyframes site-logo-spark-south {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.4);
    }
    25% {
      opacity: 0.95;
    }
    100% {
      opacity: 0;
      transform: translate3d(0.35rem, 0.8rem, 0) scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-logo,
    .site-logo__glow,
    .site-logo__field,
    .site-logo__halo,
    .site-logo__trail,
    .site-logo__flare,
    .site-logo__orbit,
    .site-logo__mark,
    .site-logo__spark {
      transition-duration: 0.001ms !important;
      animation: none !important;
    }
  }
</style>
