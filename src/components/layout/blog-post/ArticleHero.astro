---
import BlogCover from '@/components/ui/blog/BlogCover';
import ArticleMeta from './ArticleMeta.astro';
import ArticleTagList from './ArticleTagList.astro';
import '@/styles/components/article-surface.css';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  excerpt: string;
  lang: 'en' | 'th';
  slug?: string | undefined;
  tags: string[];
  pubDate: Date;
  coverImage?: ImageMetadata | undefined;
  readingTimeMin?: number | undefined;
}

const { title, excerpt, lang, slug, tags, pubDate, coverImage, readingTimeMin } =
  Astro.props as Props;
---

<section
  class="article-hero article-surface"
  data-lang={lang}
  data-has-cover={coverImage ? 'true' : 'false'}
>
  <div class="article-hero__background" aria-hidden="true">
    <BlogCover
      title={title}
      excerpt={excerpt}
      lang={lang}
      routeSlug={slug ?? title}
      tags={tags}
      pubDate={pubDate}
      coverImageSrc={coverImage?.src}
      imageLoading="eager"
      imageFetchPriority="high"
      imageDecoding="sync"
      imageWidth={coverImage?.width}
      imageHeight={coverImage?.height}
      variant="hero"
      renderMode="background"
      className="article-hero__cover"
    />
  </div>

  <div class="article-hero__content">
    <a href="/blog" class="article-back">
      <span class="article-back__icon" aria-hidden="true">←</span>
      All posts
    </a>
    <h1 class="article-hero__title">{title}</h1>
    <div class="article-hero__meta-row">
      <ArticleMeta pubDate={pubDate} readingTimeMin={readingTimeMin} />
      {tags.length ? <ArticleTagList tags={tags} /> : null}
    </div>
  </div>
</section>

<style>
  .article-hero {
    position: relative;
    display: flex;
    inline-size: 100dvw;
    margin-inline: calc(50% - 50dvw);
    min-height: clamp(24rem, 34vw, 31rem);
    align-items: flex-start;
    overflow: hidden;
    border-inline: 0;
    border-radius: 0;
    padding: clamp(1.35rem, 2.4vw, 2.45rem) clamp(1.35rem, 2vw + 1rem, 2.8rem)
      clamp(4.75rem, 10vw, 7rem);
  }

  .article-hero__background,
  .article-hero__background::before,
  .article-hero__background::after {
    position: absolute;
    inset: 0;
  }

  .article-hero__background {
    z-index: 0;
  }

  .article-hero__background::before {
    content: '';
    z-index: 1;
    background:
      radial-gradient(
        90% 90% at 76% 12%,
        color-mix(in oklab, var(--accent-blog) 24%, transparent),
        transparent 56%
      ),
      linear-gradient(
        90deg,
        rgba(3, 7, 18, 0.82) 0%,
        rgba(3, 7, 18, 0.58) 52%,
        rgba(3, 7, 18, 0.34) 100%
      ),
      linear-gradient(
        180deg,
        rgba(3, 7, 18, 0.08) 0%,
        rgba(3, 7, 18, 0.5) 76%,
        rgba(3, 7, 18, 0.88) 100%
      );
    pointer-events: none;
  }

  .article-hero__background::after {
    content: '';
    z-index: 2;
    background-image:
      radial-gradient(1.4px 1.4px at 12% 22%, rgba(255, 255, 255, 0.2), transparent 60%),
      radial-gradient(1px 1px at 72% 18%, rgba(191, 219, 254, 0.22), transparent 65%),
      radial-gradient(1.6px 1.6px at 84% 64%, rgba(165, 180, 252, 0.18), transparent 70%),
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size:
      30rem 30rem,
      26rem 26rem,
      34rem 34rem,
      88px 88px,
      88px 88px;
    opacity: 0.18;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .article-hero :global(.article-hero__cover) {
    height: 100%;
    min-height: 100%;
    border: none;
    box-shadow: none;
    filter: saturate(1.08) blur(4px);
    transform: scale(1.025);
  }

  .article-hero__content {
    position: relative;
    z-index: 3;
    display: grid;
    width: min(var(--article-content-width, 60rem), calc(100% - 2rem));
    gap: clamp(1rem, 1.8vw, 1.35rem);
    margin-inline: auto;
    padding-block: clamp(0.35rem, 1vw, 1rem);
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.55rem;
    margin-bottom: clamp(0.25rem, 0.7vw, 0.55rem);
    padding: 0.35rem 0;
    color: color-mix(in oklab, var(--white) 82%, transparent);
    font-size: var(--type-control);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent-blog) 28%, transparent);
    text-shadow: 0 12px 30px rgba(3, 7, 18, 0.72);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .article-back:hover {
    transform: translateX(-2px);
    color: color-mix(in oklab, var(--accent-blog) 80%, var(--white) 30%);
    border-color: color-mix(in oklab, var(--accent-blog) 55%, transparent);
  }

  .article-back__icon {
    font-size: var(--type-body);
  }

  .article-hero__title {
    margin: 0;
    max-width: 22ch;
    color: var(--white);
    font-size: var(--type-page-title);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
    text-shadow: 0 20px 56px rgba(3, 7, 18, 0.66);
  }

  .article-hero[data-lang='th'] .article-hero__title {
    max-width: 24ch;
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  .article-hero__meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1rem;
    max-width: 54rem;
  }

  @media (max-width: 720px) {
    .article-hero {
      min-height: clamp(23rem, 104vw, 32rem);
      padding: 1.15rem 1.15rem clamp(3.25rem, 12vw, 5rem);
    }

    .article-hero__background::before {
      background:
        linear-gradient(
          180deg,
          rgba(3, 7, 18, 0.18) 0%,
          rgba(3, 7, 18, 0.54) 48%,
          rgba(3, 7, 18, 0.9) 100%
        ),
        linear-gradient(90deg, rgba(3, 7, 18, 0.72), rgba(3, 7, 18, 0.28));
    }

    .article-hero__title {
      max-width: 100%;
      font-size: var(--type-page-title-compact);
      line-height: 1.08;
    }

    .article-hero__meta-row {
      gap: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-back {
      transition-duration: 0.01ms;
    }

    .article-back:hover {
      transform: none;
    }
  }
</style>
