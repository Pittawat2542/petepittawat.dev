---
import BlogCover from '@/components/ui/blog/BlogCover';
import ArticleMeta from './ArticleMeta.astro';
import ArticleTagList from './ArticleTagList.astro';
import '@/styles/components/article-surface.css';

interface Props {
  title: string;
  excerpt: string;
  lang: 'en' | 'th';
  slug?: string | undefined;
  tags: string[];
  pubDate: Date;
  readingTimeMin?: number | undefined;
}

const { title, excerpt, lang, slug, tags, pubDate, readingTimeMin } = Astro.props as Props;
---

<section class="article-surface article-hero">
  <div class="article-hero__background" aria-hidden="true">
    <BlogCover
      title={title}
      excerpt={excerpt}
      lang={lang}
      routeSlug={slug ?? title}
      tags={tags}
      pubDate={pubDate}
      variant="hero"
      renderMode="background"
      className="article-hero__cover"
    />
  </div>

  <div class="article-hero__overlay">
    <div class="article-hero__badge">
      <span class="article-hero__badge-dot"></span>
      Field Notes
    </div>
    <h1 class="article-hero__title">{title}</h1>
    <ArticleMeta pubDate={pubDate} readingTimeMin={readingTimeMin} />
    <ArticleTagList tags={tags} />
  </div>
</section>

<style>
  .article-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: clamp(25rem, 52vw, 42rem);
    align-items: flex-end;
    overflow: hidden;
    padding: clamp(1.5rem, 1rem + 1.8vw, 2.5rem);
  }

  .article-hero__background {
    position: absolute;
    inset: 0;
  }

  .article-hero__background::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(3, 7, 18, 0.84) 0%,
        rgba(3, 7, 18, 0.62) 46%,
        rgba(3, 7, 18, 0.24) 76%,
        rgba(3, 7, 18, 0.1) 100%
      ),
      linear-gradient(
        180deg,
        rgba(4, 8, 18, 0.05) 0%,
        rgba(4, 8, 18, 0.16) 42%,
        rgba(4, 8, 18, 0.7) 100%
      );
    pointer-events: none;
  }

  .article-hero__overlay {
    position: relative;
    z-index: 1;
    display: flex;
    width: min(100%, 48rem);
    min-width: 0;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.15rem;
  }

  .article-hero__badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.6rem;
    padding: 0.52rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--white) 14%, transparent);
    background: color-mix(in oklab, var(--white) 5%, transparent);
    color: color-mix(in oklab, var(--white) 78%, transparent);
    font-size: var(--type-meta);
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .article-hero__badge-dot {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent-blog) 84%, transparent);
    box-shadow: 0 0 14px rgba(129, 140, 248, 0.55);
  }

  .article-hero__title {
    margin: 0;
    max-width: 13ch;
    font-size: var(--type-page-title);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
    text-shadow: 0 18px 46px rgba(3, 7, 18, 0.42);
  }

  .article-hero :global(.article-hero__cover) {
    height: 100%;
    min-height: 100%;
    border: none;
    box-shadow: none;
  }

  @media (max-width: 1100px) {
    .article-hero {
      min-height: clamp(23rem, 66vw, 34rem);
    }

    .article-hero__overlay {
      width: min(100%, 40rem);
    }

    .article-hero__title {
      max-width: 14ch;
    }
  }

  @media (max-width: 720px) {
    .article-hero {
      padding: 1.35rem;
      min-height: clamp(22rem, 96vw, 31rem);
    }

    .article-hero__background::after {
      background:
        linear-gradient(
          180deg,
          rgba(4, 8, 18, 0.16) 0%,
          rgba(4, 8, 18, 0.42) 44%,
          rgba(4, 8, 18, 0.86) 100%
        ),
        linear-gradient(
          90deg,
          rgba(3, 7, 18, 0.54) 0%,
          rgba(3, 7, 18, 0.22) 72%,
          rgba(3, 7, 18, 0.08) 100%
        );
    }

    .article-hero__overlay {
      width: 100%;
      gap: 1rem;
    }

    .article-hero__title {
      max-width: none;
      font-size: var(--type-page-title-compact);
    }
  }
</style>
