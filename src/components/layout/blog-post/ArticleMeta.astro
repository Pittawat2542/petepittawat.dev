---
import { Calendar, CircleUser, Clock3 } from 'lucide-react';
import FormattedDate from '@/components/content/FormattedDate';

interface Props {
  readonly pubDate: Date;
  readonly readingTimeMin?: number | undefined;
  readonly author?: string | undefined;
}

const { pubDate, readingTimeMin, author = 'Pete' } = Astro.props as Props;
---

<div class="article-meta">
  <div class="article-meta__item">
    <span class="sr-only">Published</span>
    <Calendar className="article-meta__icon" aria-hidden="true" />
    <span class="article-meta__text"><FormattedDate date={pubDate} /></span>
  </div>
  <div class="article-meta__divider" aria-hidden="true">·</div>
  <div class="article-meta__item">
    <span class="sr-only">Author</span>
    <CircleUser className="article-meta__icon" aria-hidden="true" />
    <span class="article-meta__text">{author}</span>
  </div>
  {
    typeof readingTimeMin === 'number' ? (
      <>
        <div class="article-meta__divider" aria-hidden="true">
          ·
        </div>
        <div class="article-meta__item">
          <span class="sr-only">Reading time</span>
          <Clock3 className="article-meta__icon" aria-hidden="true" />
          <span class="article-meta__text">{readingTimeMin} min read</span>
        </div>
      </>
    ) : null
  }
</div>

<style>
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    font-size: var(--type-body-sm);
    color: color-mix(in oklab, var(--white) 78%, transparent);
  }

  .article-meta__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .article-meta__icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.74;
  }

  .article-meta__text {
    font-weight: 650;
    color: color-mix(in oklab, var(--white) 92%, transparent);
  }

  .article-meta__divider {
    opacity: 0.3;
  }

  @media (max-width: 720px) {
    .article-meta {
      font-size: var(--type-control);
    }
  }
</style>
