---
import { Tag as TagIcon } from '@lucide/astro';
import { slugifyTag } from '@/lib/slug';

interface Props {
  readonly tags: readonly string[];
}

const { tags } = Astro.props as Props;
---

{
  tags.length ? (
    <div class="article-tags">
      <span class="article-tags__icon">
        <span class="sr-only">Tags</span>
        <TagIcon class="article-tags__symbol" aria-hidden="true" />
      </span>
      <ul class="article-tags__list">
        {tags.map(tag => (
          <li>
            <a href={`/tags/${slugifyTag(tag)}`} class="article-tag">
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ) : null
}

<style>
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .article-tags__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--white) 12%, transparent);
    background: color-mix(in oklab, var(--white) 6%, transparent);
  }

  .article-tags__symbol {
    width: 1rem;
    height: 1rem;
    color: color-mix(in oklab, var(--accent-blog) 82%, white 16%);
  }

  .article-tags__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.42rem 0.82rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--accent-blog) 32%, transparent);
    background: rgba(18, 28, 52, 0.72);
    color: color-mix(in oklab, var(--accent-blog) 86%, white 14%);
    font-size: 0.78rem;
    font-weight: 600;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .article-tag:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--accent-blog) 48%, transparent);
    background: rgba(26, 38, 69, 0.82);
  }

  @media (max-width: 720px) {
    .article-tag {
      font-size: 0.72rem;
      padding: 0.34rem 0.72rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-tag {
      transition-duration: 0.01ms;
    }

    .article-tag:hover {
      transform: none;
    }
  }
</style>
