---
import type { CSSProperties } from 'react';
import { THEMED_PAGE_HERO_STYLES } from './themedPageHeroStyles';

interface Props {
  title: string;
  subtitle?: string;
  page: string;
}

const { title, subtitle, page } = Astro.props;

const formatPageLabel = (value: string) =>
  value
    .split(/[-_]+/g)
    .filter(Boolean)
    .map(segment => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(' ');

const heroStyle = {
  '--hero-accent': 'var(--accent, #6ac1ff)',
} as CSSProperties;

const sectionLabel = formatPageLabel(page) || 'Overview';
---

<section class="themed-hero" style={heroStyle} data-page={page}>
  <div class="themed-hero__backdrop" aria-hidden="true">
    <div class="themed-hero__gradient"></div>
    <div class="themed-hero__beam themed-hero__beam--one"></div>
    <div class="themed-hero__beam themed-hero__beam--two"></div>
    <div class="themed-hero__grid"></div>
    <div class="themed-hero__orb themed-hero__orb--one"></div>
    <div class="themed-hero__orb themed-hero__orb--two"></div>
  </div>
  <div class="themed-hero__shine" aria-hidden="true"></div>
  <div class="themed-hero__inner">
    <span class="themed-hero__badge">
      <span class="themed-hero__badge-dot"></span>
      {sectionLabel}
    </span>
    <h1 class="themed-hero__title">{title}</h1>
    {subtitle ? <p class="themed-hero__subtitle">{subtitle}</p> : null}
    <div class="themed-hero__actions">
      <slot />
    </div>
  </div>
</section>

<style is:inline set:html={THEMED_PAGE_HERO_STYLES}></style>
