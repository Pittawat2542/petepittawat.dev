---
import { BookOpenText, FolderKanban, FileText, Mic, CircleUser, ExternalLink } from '@lucide/astro';
import BrandIcon from '@/components/ui/icons/BrandIcon.astro';
import { socialLinks } from './footer-social-links';
import { siteCopyEn } from '@/data/site/copy';

const siteCopy = siteCopyEn;
const year = new Date().getFullYear();
const navLinks = siteCopy.nav.links;
const quickLinks = [
  {
    href: '/blog',
    label: navLinks.find(link => link.key === 'blog')?.label ?? 'Blog',
    icon: BookOpenText,
  },
  {
    href: '/projects',
    label: navLinks.find(link => link.key === 'projects')?.label ?? 'Projects',
    icon: FolderKanban,
  },
  {
    href: '/publications',
    label: navLinks.find(link => link.key === 'publications')?.label ?? 'Publications',
    icon: FileText,
  },
  {
    href: '/talks',
    label: navLinks.find(link => link.key === 'talks')?.label ?? 'Talks',
    icon: Mic,
  },
  {
    href: '/about',
    label: navLinks.find(link => link.key === 'about')?.label ?? 'About',
    icon: CircleUser,
  },
];
---

<footer class="site-footer" style="view-transition-name: site-footer;">
  <div class="site-footer__container">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <h2 class="site-footer__title">{siteCopy.footer.title}</h2>
        <p class="site-footer__summary">
          {siteCopy.footer.summary}
        </p>
      </div>
      <div class="site-footer__links">
        {
          quickLinks.map(({ href, label, icon: Icon }) => (
            <a href={href} class="site-footer__link">
              <Icon class="site-footer__icon" aria-hidden="true" />
              <span>{label}</span>
            </a>
          ))
        }
      </div>
      <div class="site-footer__contact">
        {
          socialLinks.map(({ href, label, brandIcon, customIcon }) => (
            <a
              href={href}
              title={label}
              aria-label={label}
              rel="noopener noreferrer"
              target="_blank"
              class="site-footer__contact-link"
            >
              {brandIcon && <BrandIcon icon={brandIcon} class="site-footer__icon" />}
              {customIcon === 'linkedin' && (
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="site-footer__icon"
                  aria-hidden="true"
                >
                  <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.67H9.32V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.61 0 4.28 2.38 4.28 5.47v6.28zM5.3 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.52V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0z" />
                </svg>
              )}
              <span>{label}</span>
              <ExternalLink class="site-footer__icon" aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <div class="site-footer__bottom">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <p class="text-center md:text-left">
        &copy; 2020-{year} Pittawat Taveekitworachai. All rights reserved.
      </p>
      <div class="flex items-center justify-center md:justify-end">
        <a
          href="https://webring.wonderful.software#petepittawat.dev"
          title="Thai Webring"
          aria-label="Thai Webring"
          rel="noopener noreferrer"
          target="_blank"
          class="site-footer__contact-link webring-link"
        >
          <img
            alt="Thai Webring"
            class="webring-icon h-7 w-7 rounded-full border border-white/10 bg-white/8 p-1"
            src="https://webring.wonderful.software/webring.white.svg"
            loading="lazy"
            decoding="async"
          />
          <span class="ml-2">{siteCopy.footer.webringLabel}</span>
          <ExternalLink class="site-footer__icon ml-1" aria-hidden="true" size={14} />
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(5, 9, 18, 0.92);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
  }

  .site-footer__container {
    max-width: min(1100px, 92vw);
    margin: 0 auto;
    padding: 2.5rem clamp(1.5rem, 4vw, 2.75rem);
  }

  .site-footer__grid {
    display: grid;
    column-gap: clamp(1rem, 4vw, 2rem);
    row-gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .site-footer__brand {
    grid-column: 1 / -1;
    min-width: 0;
  }

  .site-footer__title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.1rem, 4.2vw, 1.3rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
  }

  .site-footer__summary {
    margin: 0;
    max-width: 36rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .site-footer__links,
  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-footer__links {
    justify-self: start;
  }

  .site-footer__contact {
    justify-self: start;
  }

  .site-footer__link,
  .site-footer__contact-link {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.9rem;
    transition: color 160ms ease;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible,
  .site-footer__contact-link:hover,
  .site-footer__contact-link:focus-visible {
    color: rgba(255, 255, 255, 0.92);
  }

  :global(.site-footer__icon) {
    width: 0.95rem;
    height: 0.95rem;
    opacity: 0.7;
    transition:
      opacity 160ms ease,
      transform 200ms ease;
  }

  .site-footer__link:hover :global(.site-footer__icon),
  .site-footer__link:focus-visible :global(.site-footer__icon),
  .site-footer__contact-link:hover :global(.site-footer__icon),
  .site-footer__contact-link:focus-visible :global(.site-footer__icon) {
    opacity: 1;
    transform: translateY(-1px);
  }

  .site-footer__bottom {
    margin: 0 auto;
    max-width: min(1100px, 92vw);
    padding: 1.25rem clamp(1.5rem, 4vw, 2.75rem) 1.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
  }

  @media (min-width: 560px) {
    .site-footer__title {
      white-space: nowrap;
    }
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      column-gap: clamp(2rem, 7vw, 6rem);
    }

    .site-footer__summary {
      max-width: 46rem;
    }

    .site-footer__bottom {
      text-align: right;
    }
  }
</style>
