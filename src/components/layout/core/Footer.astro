---
import { ExternalLink } from '@lucide/astro';
import SiteLogo from '@/components/header/SiteLogo.astro';
import BrandIcon from '@/components/ui/icons/BrandIcon.astro';
import { socialLinks } from './footer-social-links';
import { siteCopyEn } from '@/data/site/copy';

const siteCopy = siteCopyEn;
const year = new Date().getFullYear();
---

<footer class="site-footer" style="view-transition-name: site-footer;">
  <div class="site-footer__container">
    <div class="site-footer__main">
      <section class="site-footer__brand" aria-label="Site summary">
        <SiteLogo showTitle class="site-footer__logo" />
      </section>
      <div class="site-footer__spacer" aria-hidden="true"></div>
      <nav class="site-footer__socials" aria-label="External profiles">
        {
          socialLinks.map(({ href, label, brandIcon, customIcon }) => (
            <a
              href={href}
              title={label}
              aria-label={label}
              rel="noopener noreferrer"
              target="_blank"
              class="site-footer__social-link"
            >
              {brandIcon && <BrandIcon icon={brandIcon} class="site-footer__icon" />}
              {customIcon === 'linkedin' && (
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="site-footer__icon"
                  aria-hidden="true"
                >
                  <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.67H9.32V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.61 0 4.28 2.38 4.28 5.47v6.28zM5.3 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.52V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0z" />
                </svg>
              )}
              <span class="site-footer__social-label">{label}</span>
              <ExternalLink
                class="site-footer__icon site-footer__social-external"
                aria-hidden="true"
                size={14}
              />
            </a>
          ))
        }
      </nav>
    </div>
  </div>
  <div class="site-footer__bottom">
    <div class="site-footer__bottom-inner">
      <p class="site-footer__copyright">
        &copy; 2020-{year} Pittawat Taveekitworachai. All rights reserved.
      </p>
      <a
        href="https://webring.wonderful.software#petepittawat.dev"
        title="Thai Webring"
        aria-label="Thai Webring"
        rel="noopener noreferrer"
        target="_blank"
        class="site-footer__webring-link"
      >
        <img
          alt="Thai Webring"
          class="site-footer__webring-icon"
          src="https://webring.wonderful.software/webring.white.svg"
          loading="lazy"
          decoding="async"
        />
        <span>{siteCopy.footer.webringLabel}</span>
        <ExternalLink class="site-footer__icon" aria-hidden="true" size={14} />
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--site-chrome-border);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--white, #f9fafb) 3%, transparent),
        transparent 42%
      ),
      var(--site-chrome-bg-strong);
    box-shadow: inset 0 1px 0 color-mix(in oklab, var(--white, #f9fafb) 6%, transparent);
    color: var(--site-chrome-link-color);
  }

  .site-footer__container {
    max-width: min(100%, var(--site-chrome-max-width));
    margin: 0 auto;
    padding: clamp(1.4rem, 3vw, 2.3rem) var(--site-chrome-padding-x);
  }

  .site-footer__main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.7rem, 4vw, 2.4rem);
    text-align: center;
  }

  .site-footer__brand {
    --site-logo-bg: linear-gradient(
      160deg,
      color-mix(
        in oklab,
        var(--page-accent, var(--accent, #6ac1ff)) 24%,
        rgba(255, 255, 255, 0.16)
      ),
      rgba(14, 22, 38, 0.92)
    );
    --site-logo-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18), 0 16px 28px -22px rgba(0, 0, 0, 0.72);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    min-width: 0;
  }

  .site-footer__brand :global(.site-footer__logo) {
    padding: 0;
    color: var(--site-chrome-link-color-active);
  }

  .site-footer__brand :global(.site-logo__title) {
    font-family: 'Anuphan', sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .site-footer__summary {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(0.92rem, 1.8vw, 0.98rem);
    line-height: 1.6;
    color: color-mix(in oklab, var(--white, #f9fafb) 66%, transparent);
  }

  .site-footer__spacer {
    display: none;
  }

  .site-footer__socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    column-gap: clamp(1.2rem, 3.2vw, 2.6rem);
    row-gap: 0.55rem;
    max-width: 100%;
  }

  .site-footer__social-link,
  .site-footer__webring-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--site-chrome-link-color);
    outline: none;
    transition:
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      background-color var(--motion-duration-fast) var(--motion-ease-standard),
      color var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .site-footer__social-link {
    width: var(--site-chrome-control-size);
    height: var(--site-chrome-control-size);
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    gap: 0.6rem;
  }

  .site-footer__social-link:hover,
  .site-footer__social-link:focus-visible,
  .site-footer__webring-link:hover,
  .site-footer__webring-link:focus-visible {
    border-color: color-mix(in oklab, var(--white, #f9fafb) 12%, transparent);
    background: color-mix(in oklab, var(--white, #f9fafb) 5%, transparent);
    color: var(--site-chrome-link-color-active);
    transform: translateY(-1px);
  }

  .site-footer__social-link:focus-visible,
  .site-footer__webring-link:focus-visible,
  .site-footer__brand :global(.site-footer__logo:focus-visible) {
    box-shadow: var(--site-chrome-focus-ring);
  }

  /* Icon Astro/React children do not receive this component's scoped attribute, so this
     escape stays local to the footer class namespace. */
  :global(.site-footer__icon) {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
    opacity: 0.76;
    transition:
      opacity var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .site-footer__social-link:hover :global(.site-footer__icon),
  .site-footer__social-link:focus-visible :global(.site-footer__icon),
  .site-footer__webring-link:hover :global(.site-footer__icon),
  .site-footer__webring-link:focus-visible :global(.site-footer__icon) {
    opacity: 1;
  }

  .site-footer__social-label {
    display: none;
    font-family: 'Anuphan', sans-serif;
    font-size: 0.84rem;
    font-weight: 560;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.site-footer__social-external) {
    display: none;
  }

  .site-footer__bottom {
    border-top: 1px solid var(--site-chrome-border);
  }

  .site-footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: min(100%, var(--site-chrome-max-width));
    margin: 0 auto;
    padding: 1rem var(--site-chrome-padding-x) 1.4rem;
    font-size: 0.85rem;
    color: color-mix(in oklab, var(--white, #f9fafb) 54%, transparent);
  }

  .site-footer__copyright {
    margin: 0;
  }

  .site-footer__webring-link {
    min-height: 2rem;
    gap: 0.5rem;
    padding: 0.25rem 0.45rem;
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 0.85rem;
  }

  .site-footer__webring-icon {
    width: 1.35rem;
    height: 1.35rem;
    flex: 0 0 auto;
    border: 1px solid color-mix(in oklab, var(--white, #f9fafb) 10%, transparent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--white, #f9fafb) 8%, transparent);
    padding: 0.18rem;
  }

  @media (max-width: 767px) {
    .site-footer__main {
      gap: 1.5rem;
    }

    .site-footer__summary {
      max-width: 36rem;
    }

    .site-footer__bottom-inner {
      flex-direction: column;
      justify-content: center;
      text-align: center;
    }
  }

  @media (min-width: 768px) {
    .site-footer__socials {
      margin-top: 0.15rem;
    }

    .site-footer__social-link {
      width: auto;
      min-height: var(--site-chrome-control-size);
      height: auto;
      justify-content: flex-start;
      padding: 0.35rem 0.5rem;
      border-radius: 999px;
    }

    .site-footer__social-label {
      display: inline-flex;
      flex: 0 1 auto;
      min-width: 0;
      color: currentColor;
    }

    :global(.site-footer__social-external) {
      display: block;
      width: 0.86rem;
      height: 0.86rem;
      opacity: 0;
      transform: translateX(-0.2rem);
    }

    .site-footer__social-link:hover :global(.site-footer__social-external),
    .site-footer__social-link:focus-visible :global(.site-footer__social-external) {
      opacity: 0.78;
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer__social-link,
    .site-footer__webring-link,
    :global(.site-footer__icon) {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
