---
import { ExternalLink } from '@lucide/astro';
import BrandIcon from '@/components/ui/icons/BrandIcon.astro';
import type { FooterSocialLink as FooterSocialLinkData } from './footer-social-links';

interface Props extends FooterSocialLinkData {}

const { href, label, brandIcon, customIcon } = Astro.props as Props;
---

<a
  href={href}
  title={label}
  aria-label={label}
  rel="noopener noreferrer"
  target="_blank"
  class="site-footer__social-link"
>
  {brandIcon && <BrandIcon icon={brandIcon} class="site-footer__icon" />}
  {
    customIcon === 'linkedin' && (
      <svg viewBox="0 0 24 24" fill="currentColor" class="site-footer__icon" aria-hidden="true">
        <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.15 1.45-2.15 2.95v5.67H9.32V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.61 0 4.28 2.38 4.28 5.47v6.28zM5.3 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.52V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0z" />
      </svg>
    )
  }
  <span class="site-footer__social-label">{label}</span>
  <ExternalLink
    class="site-footer__icon site-footer__social-external"
    aria-hidden="true"
    size={14}
  />
</a>
