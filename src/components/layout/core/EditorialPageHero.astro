---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  variant?: 'default' | 'blog' | 'showcase';
}

const { title, subtitle, eyebrow = 'Overview', variant = 'default' } = Astro.props as Props;

const pathname = Astro.url.pathname;
const isProjects =
  pathname.startsWith('/projects') || pathname === '/projects' || eyebrow === 'Selected Work';
const isPublications =
  pathname.startsWith('/publications') ||
  pathname === '/publications' ||
  eyebrow === 'Research Record';
const isTalks = pathname.startsWith('/talks') || pathname === '/talks' || eyebrow === 'Speaking';

const blogHeroStars = [
  {
    className: 'editorial-page-hero__star',
    style:
      '--star-x: 54%; --star-y: 24%; --star-size: 0.16rem; --star-delay: 120ms; --star-drift-x: -0.38rem; --star-drift-y: -0.2rem;',
  },
  {
    className: 'editorial-page-hero__star',
    style:
      '--star-x: 64%; --star-y: 38%; --star-size: 0.24rem; --star-delay: 210ms; --star-drift-x: 0.28rem; --star-drift-y: -0.34rem;',
  },
  {
    className: 'editorial-page-hero__star',
    style:
      '--star-x: 80%; --star-y: 18%; --star-size: 0.13rem; --star-delay: 310ms; --star-drift-x: 0.34rem; --star-drift-y: 0.12rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--warm',
    style:
      '--star-x: 86%; --star-y: 71%; --star-size: 0.18rem; --star-delay: 430ms; --star-drift-x: 0.24rem; --star-drift-y: 0.3rem;',
  },
  {
    className: 'editorial-page-hero__star',
    style:
      '--star-x: 72%; --star-y: 82%; --star-size: 0.12rem; --star-delay: 520ms; --star-drift-x: -0.22rem; --star-drift-y: 0.26rem;',
  },
] as const;

const projectsHeroStars = [
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--projects',
    style:
      '--star-x: 56%; --star-y: 22%; --star-size: 0.14rem; --star-delay: 100ms; --star-drift-x: -0.3rem; --star-drift-y: 0.1rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--projects',
    style:
      '--star-x: 66%; --star-y: 42%; --star-size: 0.22rem; --star-delay: 200ms; --star-drift-x: 0.2rem; --star-drift-y: -0.25rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--projects',
    style:
      '--star-x: 82%; --star-y: 26%; --star-size: 0.16rem; --star-delay: 300ms; --star-drift-x: 0.3rem; --star-drift-y: 0.2rem;',
  },
  {
    className:
      'editorial-page-hero__star editorial-page-hero__star--projects editorial-page-hero__star--cyan-warm',
    style:
      '--star-x: 74%; --star-y: 74%; --star-size: 0.18rem; --star-delay: 400ms; --star-drift-x: -0.2rem; --star-drift-y: 0.3rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--projects',
    style:
      '--star-x: 88%; --star-y: 52%; --star-size: 0.12rem; --star-delay: 500ms; --star-drift-x: 0.25rem; --star-drift-y: -0.15rem;',
  },
] as const;

const publicationsHeroStars = [
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--publications',
    style:
      '--star-x: 60%; --star-y: 15%; --star-size: 0.15rem; --star-delay: 150ms; --star-drift-x: -0.25rem; --star-drift-y: 0.2rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--publications',
    style:
      '--star-x: 72%; --star-y: 38%; --star-size: 0.2rem; --star-delay: 250ms; --star-drift-x: 0.3rem; --star-drift-y: -0.2rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--publications',
    style:
      '--star-x: 52%; --star-y: 65%; --star-size: 0.13rem; --star-delay: 350ms; --star-drift-x: -0.2rem; --star-drift-y: -0.3rem;',
  },
  {
    className:
      'editorial-page-hero__star editorial-page-hero__star--publications editorial-page-hero__star--emerald-warm',
    style:
      '--star-x: 84%; --star-y: 68%; --star-size: 0.24rem; --star-delay: 450ms; --star-drift-x: 0.25rem; --star-drift-y: 0.25rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--publications',
    style:
      '--star-x: 78%; --star-y: 82%; --star-size: 0.12rem; --star-delay: 550ms; --star-drift-x: 0.15rem; --star-drift-y: -0.2rem;',
  },
] as const;

const talksHeroStars = [
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--talks',
    style:
      '--star-x: 58%; --star-y: 30%; --star-size: 0.16rem; --star-delay: 100ms; --star-drift-x: 0.2rem; --star-drift-y: -0.2rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--talks',
    style:
      '--star-x: 68%; --star-y: 22%; --star-size: 0.22rem; --star-delay: 200ms; --star-drift-x: -0.25rem; --star-drift-y: 0.15rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--talks',
    style:
      '--star-x: 78%; --star-y: 48%; --star-size: 0.14rem; --star-delay: 300ms; --star-drift-x: 0.3rem; --star-drift-y: 0.3rem;',
  },
  {
    className:
      'editorial-page-hero__star editorial-page-hero__star--talks editorial-page-hero__star--orange-warm',
    style:
      '--star-x: 88%; --star-y: 32%; --star-size: 0.18rem; --star-delay: 400ms; --star-drift-x: -0.15rem; --star-drift-y: -0.25rem;',
  },
  {
    className: 'editorial-page-hero__star editorial-page-hero__star--talks',
    style:
      '--star-x: 84%; --star-y: 78%; --star-size: 0.12rem; --star-delay: 500ms; --star-drift-x: 0.2rem; --star-drift-y: -0.15rem;',
  },
] as const;
---

<section class="editorial-page-hero reveal" data-variant={variant}>
  <div class="editorial-page-hero__wash" aria-hidden="true"></div>
  <div class="editorial-page-hero__grid" aria-hidden="true"></div>
  {
    variant === 'blog' || variant === 'showcase' ? (
      <div
        class:list={[
          'editorial-page-hero__observatory',
          {
            'editorial-page-hero__observatory--blog': variant === 'blog',
            'editorial-page-hero__observatory--projects': isProjects,
            'editorial-page-hero__observatory--publications': isPublications,
            'editorial-page-hero__observatory--talks': isTalks,
          },
        ]}
        aria-hidden="true"
      >
        {/* Constellation SVG lines for projects */}
        {isProjects && (
          <svg
            class="editorial-page-hero__network"
            viewBox="0 0 100 100"
            preserveAspectRatio="none"
          >
            <path
              class="editorial-page-hero__line"
              d="M 56 22 L 66 42 L 82 26 L 88 52 L 74 74 L 66 42"
            />
            <path class="editorial-page-hero__line" d="M 56 22 L 74 74" />
          </svg>
        )}

        {/* Orbit/pulse lines */}
        {isPublications ? (
          <>
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--concentric-lg" />
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--concentric-md" />
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--concentric-sm" />
          </>
        ) : isTalks ? (
          <>
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--pulse-a" />
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--pulse-b" />
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--pulse-c" />
          </>
        ) : (
          <>
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--wide" />
            <span class="editorial-page-hero__orbit editorial-page-hero__orbit--tight" />
          </>
        )}

        {/* Planet container with glow */}
        <div class="editorial-page-hero__planet-container">
          <span class="editorial-page-hero__planet-glow" />
          <span class="editorial-page-hero__planet" />
        </div>

        {/* Signal dots */}
        <span class="editorial-page-hero__signal editorial-page-hero__signal--a" />
        <span class="editorial-page-hero__signal editorial-page-hero__signal--b" />

        {/* Star instances */}
        {isProjects &&
          projectsHeroStars.map(({ className, style }) => <span class={className} style={style} />)}
        {isPublications &&
          publicationsHeroStars.map(({ className, style }) => (
            <span class={className} style={style} />
          ))}
        {isTalks &&
          talksHeroStars.map(({ className, style }) => <span class={className} style={style} />)}
        {variant === 'blog' &&
          blogHeroStars.map(({ className, style }) => <span class={className} style={style} />)}
      </div>
    ) : null
  }
  <div class="editorial-page-hero__inner">
    <div class="editorial-page-hero__eyebrow">
      <span class="editorial-page-hero__eyebrow-dot"></span>
      {eyebrow}
    </div>
    <h1 class="editorial-page-hero__title">{title}</h1>
    {subtitle ? <p class="editorial-page-hero__subtitle">{subtitle}</p> : null}
    <div class="editorial-page-hero__rule" aria-hidden="true">
      <span class="editorial-page-hero__rule-accent"></span>
    </div>
    <div class="editorial-page-hero__support">
      <slot name="support" />
    </div>
  </div>
</section>

<style>
  .editorial-page-hero {
    position: relative;
    overflow: hidden;
    border-radius: clamp(1.75rem, 4vw, 2.75rem);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      radial-gradient(circle at 14% 18%, rgba(96, 165, 250, 0.24), transparent 32%),
      radial-gradient(circle at 82% 0%, rgba(59, 130, 246, 0.2), transparent 28%),
      linear-gradient(180deg, rgba(11, 21, 40, 0.96), rgba(7, 16, 31, 0.96)),
      linear-gradient(135deg, rgba(14, 25, 48, 0.85), rgba(8, 15, 30, 0.94));
    box-shadow:
      0 28px 70px -40px rgba(15, 23, 42, 0.52),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .editorial-page-hero__wash,
  .editorial-page-hero__grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .editorial-page-hero__wash {
    background:
      radial-gradient(circle at 12% 18%, rgba(147, 197, 253, 0.14), transparent 34%),
      radial-gradient(circle at 88% 0%, rgba(96, 165, 250, 0.16), transparent 36%);
  }

  .editorial-page-hero__grid {
    opacity: 0.38;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.28), transparent 72%);
  }

  .editorial-page-hero__inner {
    position: relative;
    display: grid;
    gap: 1.25rem;
    padding: clamp(1.75rem, 5vw, 3rem);
  }

  .editorial-page-hero__eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.65rem;
    color: rgba(191, 219, 254, 0.86);
    font-size: var(--type-meta);
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .editorial-page-hero__eyebrow-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--page-accent, var(--accent)) 72%, white);
    box-shadow: 0 0 0 6px color-mix(in oklab, var(--page-accent, var(--accent)) 12%, transparent);
  }

  .editorial-page-hero__title {
    margin: 0;
    max-width: 14ch;
    color: rgba(248, 250, 252, 0.98);
    font-size: var(--type-page-title);
    line-height: 0.96;
    letter-spacing: -0.055em;
    font-weight: 700;
    text-wrap: balance;
  }

  .editorial-page-hero__subtitle {
    margin: 0;
    max-width: 48rem;
    color: rgba(191, 219, 254, 0.76);
    font-size: var(--type-body-lg);
    line-height: 1.75;
    text-wrap: pretty;
  }

  .editorial-page-hero__rule {
    margin-top: 0.25rem;
    display: flex;
    align-items: center;
    width: min(100%, 28rem);
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.34), rgba(148, 163, 184, 0.06));
  }

  .editorial-page-hero__rule-accent {
    display: block;
    width: clamp(5rem, 16vw, 9rem);
    height: 2px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--page-accent, var(--accent)) 72%, white);
    box-shadow: 0 0 18px color-mix(in oklab, var(--page-accent, var(--accent)) 26%, transparent);
  }

  .editorial-page-hero__support {
    display: contents;
  }

  .editorial-page-hero[data-variant='blog'],
  .editorial-page-hero[data-variant='showcase'] {
    min-height: clamp(23rem, 35vw, 28rem);
    border-color: var(--blog-hero-border);
    border-radius: var(--blog-hero-radius);
    background: var(--blog-hero-surface);
    box-shadow: var(--blog-hero-shadow);
  }

  .editorial-page-hero[data-variant='showcase'] {
    min-height: clamp(18rem, 28vw, 23rem);
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__grid,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__grid {
    opacity: 0.16;
    background-size: 24px 24px;
    mask-image: radial-gradient(circle at 82% 40%, rgba(0, 0, 0, 0.72) 0%, transparent 68%);
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__wash,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__wash {
    background:
      radial-gradient(740px circle at 70% 48%, rgba(29, 78, 144, 0.14), transparent 66%),
      radial-gradient(500px circle at 10% 14%, rgba(255, 255, 255, 0.035), transparent 58%);
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__inner {
    width: min(52%, 40rem);
    min-height: inherit;
    align-content: center;
    gap: clamp(1rem, 2vw, 1.35rem);
    padding: clamp(2.4rem, 5.8vw, 4.35rem);
  }

  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__inner {
    width: min(100%, 52rem);
    min-height: inherit;
    align-content: center;
    gap: clamp(1rem, 2vw, 1.35rem);
    padding: clamp(2rem, 5vw, 3.8rem);
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__eyebrow,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__eyebrow {
    color: color-mix(in oklab, var(--white) 54%, var(--page-accent, var(--accent)) 30%);
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__eyebrow-dot,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__eyebrow-dot {
    width: 0.48rem;
    height: 0.48rem;
    box-shadow: none;
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__title,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__title {
    color: color-mix(in oklab, var(--white) 92%, var(--page-accent, var(--accent)) 8%);
    letter-spacing: -0.045em;
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__subtitle,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__subtitle {
    max-width: 38rem;
    color: color-mix(in oklab, var(--white) 54%, var(--page-accent, var(--accent)) 32%);
    font-size: var(--type-body-lg);
    line-height: 1.9;
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__rule,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__rule {
    width: min(100%, 30rem);
    background: linear-gradient(
      90deg,
      color-mix(in oklab, var(--page-accent, var(--accent)) 22%, transparent),
      color-mix(in oklab, var(--white) 5%, transparent) 64%,
      transparent
    );
  }

  .editorial-page-hero[data-variant='blog'] .editorial-page-hero__rule-accent,
  .editorial-page-hero[data-variant='showcase'] .editorial-page-hero__rule-accent {
    width: clamp(7rem, 14vw, 10rem);
    background: var(--blog-hero-rule);
    box-shadow: none;
  }

  .editorial-page-hero__observatory {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    animation: blog-hero-observatory-enter 820ms var(--motion-ease-decelerate) 80ms backwards;
  }

  .editorial-page-hero__planet-container {
    position: absolute;
    right: 8.5%;
    bottom: 3%;
    width: clamp(17rem, 27vw, 24rem);
    aspect-ratio: 1;
    z-index: 2;
    transition:
      right 300ms ease,
      bottom 300ms ease,
      width 300ms ease,
      translate 300ms ease;
  }

  .editorial-page-hero__planet {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background:
      radial-gradient(circle at 36% 32%, rgba(181, 217, 255, 0.18), transparent 11%),
      radial-gradient(
        circle at 38% 34%,
        color-mix(in oklab, var(--page-accent, var(--accent)) 36%, transparent),
        transparent 30%
      ),
      linear-gradient(142deg, rgba(24, 74, 135, 0.5), rgba(4, 12, 26, 0.98) 70%);
    box-shadow:
      -70px 24px 120px -78px color-mix(in oklab, var(--page-accent, var(--accent)) 56%, transparent),
      inset -56px -34px 88px rgba(2, 6, 15, 0.7),
      inset 22px 18px 80px rgba(61, 116, 190, 0.08);
    opacity: 0.62;
    transition:
      background 300ms ease,
      box-shadow 300ms ease;
  }

  .editorial-page-hero__planet-glow {
    position: absolute;
    inset: -12px;
    border-radius: 999px;
    background: transparent;
    border: 1px dashed color-mix(in oklab, var(--page-accent, var(--accent)) 22%, transparent);
    box-shadow: 0 0 40px color-mix(in oklab, var(--page-accent, var(--accent)) 12%, transparent);
    opacity: 0.8;
    animation: planet-glow-pulse 6s ease-in-out infinite;
    pointer-events: none;
    transition:
      border-color 300ms ease,
      box-shadow 300ms ease,
      transform 300ms ease;
  }

  @keyframes planet-glow-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.03);
      opacity: 0.95;
    }
  }

  .editorial-page-hero__orbit {
    position: absolute;
    right: -3%;
    border: 1px solid var(--blog-hero-orbit-line);
    border-radius: 50%;
    box-shadow: inset 0 0 32px rgba(96, 165, 250, 0.025);
    transform: rotate(-11deg);
  }

  .editorial-page-hero__orbit--wide {
    top: 14%;
    width: clamp(38rem, 64vw, 64rem);
    height: clamp(11rem, 18vw, 17rem);
  }

  .editorial-page-hero__orbit--tight {
    top: 30%;
    width: clamp(30rem, 51vw, 52rem);
    height: clamp(8rem, 13vw, 12rem);
    opacity: 0.6;
  }

  /* Projects Constellation Grid/Network */
  .editorial-page-hero__network {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .editorial-page-hero__line {
    stroke: color-mix(in oklab, var(--accent-projects) 32%, transparent);
    stroke-width: 0.5px;
    stroke-dasharray: 2 3;
    fill: none;
    animation: projects-line-pulse 4s ease-in-out infinite alternate;
  }

  @keyframes projects-line-pulse {
    0% {
      opacity: 0.15;
      stroke-dashoffset: 0;
    }
    100% {
      opacity: 0.35;
      stroke-dashoffset: 10;
    }
  }

  .editorial-page-hero__observatory--projects .editorial-page-hero__planet-container {
    right: 12%;
    bottom: -5%;
    width: clamp(16rem, 25vw, 21rem);
  }

  .editorial-page-hero__observatory--projects .editorial-page-hero__planet {
    background:
      radial-gradient(circle at 36% 32%, rgba(200, 245, 255, 0.22), transparent 12%),
      radial-gradient(
        circle at 38% 34%,
        color-mix(in oklab, var(--accent-projects) 38%, transparent),
        transparent 32%
      ),
      linear-gradient(142deg, rgba(8, 76, 96, 0.5), rgba(3, 10, 20, 0.98) 72%);
    box-shadow:
      -60px 20px 110px -70px color-mix(in oklab, var(--accent-projects) 64%, transparent),
      inset -48px -30px 80px rgba(1, 4, 12, 0.72),
      inset 20px 16px 70px rgba(6, 182, 212, 0.09);
  }

  .editorial-page-hero__observatory--projects .editorial-page-hero__planet-glow {
    border-color: color-mix(in oklab, var(--accent-projects) 22%, transparent);
    box-shadow: 0 0 40px color-mix(in oklab, var(--accent-projects) 12%, transparent);
  }

  /* Publications Concentric Orbits */
  .editorial-page-hero__orbit--concentric-lg,
  .editorial-page-hero__orbit--concentric-md,
  .editorial-page-hero__orbit--concentric-sm {
    position: absolute;
    border: 1px solid color-mix(in oklab, var(--accent-publications) 15%, transparent);
    border-radius: 50%;
    box-shadow: inset 0 0 30px rgba(16, 185, 129, 0.02);
    transform-origin: center;
    left: auto;
    right: 5%;
    top: 50%;
    translate: 0 -50%;
  }

  .editorial-page-hero__orbit--concentric-lg {
    width: clamp(28rem, 46vw, 46rem);
    height: clamp(28rem, 46vw, 46rem);
    animation: publications-orbit-rotate 40s linear infinite;
  }

  .editorial-page-hero__orbit--concentric-md {
    width: clamp(20rem, 33vw, 33rem);
    height: clamp(20rem, 33vw, 33rem);
    animation: publications-orbit-rotate 28s linear infinite reverse;
    opacity: 0.75;
  }

  .editorial-page-hero__orbit--concentric-sm {
    width: clamp(12rem, 20vw, 20rem);
    height: clamp(12rem, 20vw, 20rem);
    animation: publications-orbit-rotate 18s linear infinite;
    opacity: 0.55;
  }

  @keyframes publications-orbit-rotate {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
