---
import '@/styles/components/toc.css';

import { ChevronDown, List } from '@lucide/astro';

interface Props {
  title?: string;
  selector?: string; // CSS selector for the article root
  levels?: Array<2 | 3 | 4 | 5 | 6>;
  collapsed?: boolean;
  variant?: 'card' | 'embedded';
}

const {
  title = 'Table of contents',
  selector = 'article',
  levels = [2, 3],
  collapsed = true,
  variant = 'card',
} = Astro.props as Props;
const isEmbedded = variant === 'embedded';
---

<nav
  class:list={['toc-root', isEmbedded && 'toc-root--embedded']}
  aria-label="Table of contents"
  data-selector={selector}
  data-levels={JSON.stringify(levels)}
  data-open={isEmbedded || !collapsed}
  data-variant={variant}
>
  {
    isEmbedded ? (
      <section class="toc-card" data-toc-shell>
        <div class="toc-summary toc-summary--static">
          <span class="toc-summary__content">
            <span class="toc-summary__eyebrow">
              <span class="toc-summary__icon" aria-hidden="true">
                <List class="h-[14px] w-[14px]" aria-hidden="true" />
              </span>
              Contents
            </span>
            <span class="toc-summary__title-row">
              <span class="toc-summary__label">{title}</span>
              <span class="toc-summary__count" />
            </span>
          </span>
        </div>
        <div class="toc-panel">
          <ul class="toc-list" />
        </div>
      </section>
    ) : (
      <details class="toc-card">
        <summary class="toc-summary">
          <span class="toc-summary__content">
            <span class="toc-summary__eyebrow">
              <span class="toc-summary__icon" aria-hidden="true">
                <List class="h-[14px] w-[14px]" aria-hidden="true" />
              </span>
              Contents
            </span>
            <span class="toc-summary__title-row">
              <span class="toc-summary__label">{title}</span>
              <span class="toc-summary__count" />
            </span>
          </span>
          <span class="toc-summary__action" aria-hidden="true">
            <ChevronDown class="toc-summary__chevron" aria-hidden="true" />
          </span>
        </summary>
        <div class="toc-panel">
          <ul class="toc-list" />
        </div>
      </details>
    )
  }
</nav>

<script>
  import '@/scripts/toc';
</script>
