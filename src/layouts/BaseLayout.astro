---
import BaseHead from '@/components/layout/core/BaseHead.astro';
import Footer from '@/components/layout/core/Footer.astro';
import Header from '@/components/layout/core/Header.astro';
import ScrollTop from '@/components/layout/blog/ScrollTop';
import RevealController from '@/components/common/RevealController.astro';
import { serializeCssVariables } from '@/lib/blog-cover';

const {
  title,
  description,
  lang = 'en',
  alternateLanguages = [],
  image,
  type,
  publishedTime,
  tags,
  wordCount,
  page,
  themeVariables = {},
} = Astro.props as {
  title: string;
  description: string;
  lang?: 'en' | 'th';
  alternateLanguages?: { lang: 'en' | 'th'; href: string }[];
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  wordCount?: number;
  page?: string;
  themeVariables?: Record<string, string>;
};
const ogImagePath = image ?? '/home-og-image.jpeg';
const ogImage = Astro.site ? new URL(ogImagePath, Astro.site).href : ogImagePath;
const pageKey = page?.toLowerCase();
const pageAccent = pageKey ? 'var(--accent, var(--color-accent-primary))' : undefined;
const bodyStyleFragments = [
  pageAccent ? `--page-accent:${pageAccent};--card-accent:${pageAccent};` : undefined,
  Object.keys(themeVariables).length > 0 ? serializeCssVariables(themeVariables) : undefined,
].filter(Boolean);
const bodyStyle = bodyStyleFragments.length > 0 ? bodyStyleFragments.join(';') : undefined;
const bodyClasses = pageKey ? ['page-theme', `page-theme--${pageKey}`] : [];
---

<!doctype html>
<html
  lang={lang}
  style="background:var(--surface-page);color:var(--text-primary);color-scheme: dark;"
>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImage}
      type={type || undefined}
      publishedTime={publishedTime || undefined}
      tags={tags || undefined}
      wordCount={wordCount}
      lang={lang}
      alternateLanguages={alternateLanguages}
    />
    <slot name="head" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body data-page={pageKey || undefined} class:list={bodyClasses} style={bodyStyle}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main
      id="main-content"
      tabindex="-1"
      class="page-shell mx-auto mb-12 max-w-screen-lg px-6 pt-28 md:max-w-screen-xl md:px-10"
      style="view-transition-name: page;"
    >
      <slot />
    </main>
    <Footer />
    <ScrollTop />
    <RevealController />
  </body>
</html>
