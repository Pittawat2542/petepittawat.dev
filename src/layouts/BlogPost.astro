---
import type { CollectionEntry } from 'astro:content';
import ArticleBody from '@/components/layout/blog-post/ArticleBody.astro';
import ArticleHero from '@/components/layout/blog-post/ArticleHero.astro';
import ArticleRail from '@/components/layout/blog-post/ArticleRail.astro';
import PageBackdrop from '@/components/layout/core/PageBackdrop.astro';
import ReadingProgressBar from '@/components/layout/core/ReadingProgressBar';
import { useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  getBlogCoverCssVariables,
  resolveBlogCoverSpec,
  serializeCssVariables,
} from '@/lib/blog-cover';
import { computeBlogPostMetadata, generateBlogPostSchema } from '@/lib/blog-post-schema';
import type { BlogPostLanguageState } from '@/lib/blog-translations';

type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  lang?: 'en' | 'th';
  wordCount?: number;
  readingTimeMin?: number;
  languageState: BlogPostLanguageState<CollectionEntry<'blog'>>;
  alternateLanguages?: { lang: 'en' | 'th'; href: string }[];
};

const {
  title,
  excerpt,
  pubDate,
  tags,
  coverImage,
  slug,
  lang = 'en',
  wordCount,
  readingTimeMin,
  seriesSlug,
  seriesTitle,
  seriesOrder,
  languageState,
  alternateLanguages = [],
} = Astro.props as Props;

const t = useTranslations(lang);
const languageHelperText = !languageState.availability.en.available
  ? t('blog.onlyInThai')
  : !languageState.availability.th.available
    ? t('blog.onlyInEnglish')
    : undefined;

const coverSpec =
  slug !== undefined
    ? resolveBlogCoverSpec({
        title,
        excerpt,
        lang,
        routeSlug: slug,
        tags,
        pubDate,
      })
    : undefined;
const coverThemeVariables = coverSpec ? getBlogCoverCssVariables(coverSpec.theme) : {};
const coverThemeStyle =
  Object.keys(coverThemeVariables).length > 0
    ? serializeCssVariables(coverThemeVariables)
    : undefined;

const twitterHandle = import.meta.env.PUBLIC_TWITTER_HANDLE;
const metadata = computeBlogPostMetadata({
  slug,
  lang,
  tags,
  site: Astro.site,
  twitterHandle,
});
const { canonicalUrl, imageUrl, authorUrl, authorSameAs } = metadata;

const siteUrl = Astro.site ? Astro.site.href : '/';
const schema = generateBlogPostSchema({
  title,
  excerpt,
  pubDate,
  wordCount,
  canonicalUrl,
  imageUrl,
  authorUrl,
  authorSameAs,
  siteUrl,
  seriesSlug,
  seriesTitle,
  seriesOrder,
});
---

<BaseLayout
  title={`${title} - PETEPITTAWAT.DEV`}
  description={excerpt}
  lang={lang}
  alternateLanguages={alternateLanguages}
  image={coverSpec?.ogImagePath}
  type="article"
  publishedTime={pubDate.toISOString?.() ?? String(pubDate)}
  tags={tags}
  wordCount={wordCount}
  page="blog"
  themeVariables={coverThemeVariables}
>
  <PageBackdrop variant="article" style={coverThemeStyle} />
  <ReadingProgressBar />
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </Fragment>

  <div class="article-container">
    <div class="article-back">
      <a href="/blog" class="article-back__link">
        <span class="article-back__icon" aria-hidden="true">←</span>
        All posts
      </a>
    </div>

    <ArticleHero
      title={title}
      excerpt={excerpt}
      lang={lang}
      slug={slug}
      tags={tags}
      pubDate={pubDate}
      coverImage={coverImage}
      readingTimeMin={readingTimeMin}
    />

    <div class="article-main">
      <ArticleRail
        excerpt={excerpt}
        languageState={languageState}
        languageHelperText={languageHelperText}
      />

      <ArticleBody>
        <slot />
      </ArticleBody>
    </div>
  </div>

  <div class="article-related">
    <slot name="after" />
  </div>
</BaseLayout>

<style>
  .article-container {
    position: relative;
    margin: 0 auto;
    max-width: min(74rem, 100%);
    padding: clamp(1.5rem, 2vw + 0.65rem, 3rem) 0;
  }

  .article-back {
    margin-bottom: clamp(1.4rem, 1.8vw, 2rem);
  }

  .article-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.35rem 0;
    color: color-mix(in oklab, var(--white) 82%, transparent);
    font-size: var(--type-control);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent-blog) 24%, transparent);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .article-back__link:hover {
    transform: translateX(-2px);
    color: color-mix(in oklab, var(--accent-blog) 80%, var(--white) 30%);
    border-color: color-mix(in oklab, var(--accent-blog) 50%, transparent);
  }

  .article-back__icon {
    font-size: var(--type-body);
  }

  .article-main {
    margin-top: clamp(1.5rem, 2vw, 2.25rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.25rem, 1.8vw, 2rem);
    align-items: start;
  }

  .article-related {
    margin: clamp(3rem, 4vw, 4.25rem) auto 0;
    max-width: min(74rem, 100%);
  }

  @media (max-width: 720px) {
    .article-container {
      padding: 1.2rem 0 2.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-back__link {
      transition-duration: 0.01ms;
    }

    .article-back__link:hover {
      transform: none;
    }
  }
</style>

<script>
  import '@/scripts/blog-post.ts';
</script>
