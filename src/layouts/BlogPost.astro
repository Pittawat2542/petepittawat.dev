---
import type { CollectionEntry } from 'astro:content';
import ArticleBrief from '@/components/layout/blog-post/ArticleBrief.astro';
import ArticleBody from '@/components/layout/blog-post/ArticleBody.astro';
import ArticleHero from '@/components/layout/blog-post/ArticleHero.astro';
import ArticleRail from '@/components/layout/blog-post/ArticleRail.astro';
import PageBackdrop from '@/components/layout/core/PageBackdrop.astro';
import ReadingProgressBar from '@/components/layout/core/ReadingProgressBar';
import { useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  getBlogCoverCssVariables,
  resolveBlogCoverSpec,
  serializeCssVariables,
} from '@/lib/blog-cover';
import { computeBlogPostMetadata, generateBlogPostSchema } from '@/lib/blog-post-schema';
import type { BlogPostLanguageState } from '@/lib/blog-translations';
import { SITE_TITLE } from '@/consts';

type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  lang?: 'en' | 'th';
  wordCount?: number;
  readingTimeMin?: number;
  languageState: BlogPostLanguageState<CollectionEntry<'blog'>>;
  alternateLanguages?: { lang: 'en' | 'th'; href: string }[];
};

const {
  title,
  excerpt,
  pubDate,
  tags,
  coverImage,
  slug,
  lang = 'en',
  wordCount,
  readingTimeMin,
  seriesSlug,
  seriesTitle,
  seriesOrder,
  languageState,
  alternateLanguages = [],
} = Astro.props as Props;

const t = useTranslations(lang);
const languageHelperText = !languageState.availability.en.available
  ? t('blog.onlyInThai')
  : !languageState.availability.th.available
    ? t('blog.onlyInEnglish')
    : undefined;

const coverSpec =
  slug !== undefined
    ? resolveBlogCoverSpec({
        title,
        excerpt,
        lang,
        routeSlug: slug,
        tags,
        pubDate,
      })
    : undefined;
const coverThemeVariables = coverSpec ? getBlogCoverCssVariables(coverSpec.theme) : {};
const coverThemeStyle =
  Object.keys(coverThemeVariables).length > 0
    ? serializeCssVariables(coverThemeVariables)
    : undefined;

const twitterHandle = import.meta.env.PUBLIC_TWITTER_HANDLE;
const metadata = computeBlogPostMetadata({
  slug,
  lang,
  tags,
  site: Astro.site,
  twitterHandle,
});
const { canonicalUrl, imageUrl, authorUrl, authorSameAs } = metadata;

const siteUrl = Astro.site ? Astro.site.href : '/';
const schema = generateBlogPostSchema({
  title,
  excerpt,
  pubDate,
  wordCount,
  canonicalUrl,
  imageUrl,
  authorUrl,
  authorSameAs,
  siteUrl,
  seriesSlug,
  seriesTitle,
  seriesOrder,
});
---

<BaseLayout
  title={`${title} - ${SITE_TITLE}`}
  description={excerpt}
  lang={lang}
  alternateLanguages={alternateLanguages}
  image={coverSpec?.ogImagePath}
  type="article"
  publishedTime={pubDate.toISOString?.() ?? String(pubDate)}
  tags={tags}
  wordCount={wordCount}
  page="blog"
  themeVariables={coverThemeVariables}
>
  <div class="article-header-glow" aria-hidden="true"></div>
  <PageBackdrop variant="article" style={coverThemeStyle} />
  <ReadingProgressBar />
  <Fragment slot="head">
    {
      coverImage ? (
        <link rel="preload" as="image" href={coverImage.src} fetchpriority="high" />
      ) : null
    }
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </Fragment>

  <div class="article-container">
    <ArticleHero
      title={title}
      excerpt={excerpt}
      lang={lang}
      slug={slug}
      tags={tags}
      pubDate={pubDate}
      coverImage={coverImage}
      readingTimeMin={readingTimeMin}
    />

    <div class="article-main">
      <div class="article-body-column">
        <ArticleBrief excerpt={excerpt} />
        <ArticleBody>
          <slot />
        </ArticleBody>
      </div>

      <ArticleRail languageState={languageState} languageHelperText={languageHelperText} />
    </div>
  </div>

  <div class="article-related">
    <slot name="after" />
  </div>
</BaseLayout>

<style>
  .article-header-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: clamp(350px, 45vw, 650px);
    background:
      radial-gradient(
        circle at 50% 30%,
        rgba(99, 102, 241, 0.22) 0%,
        rgba(124, 58, 237, 0.12) 42%,
        transparent 70%
      ),
      radial-gradient(circle at 35% 20%, rgba(59, 130, 246, 0.15) 0%, transparent 55%),
      radial-gradient(circle at 65% 45%, rgba(167, 139, 250, 0.12) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .article-container,
  .article-related {
    --article-content-width: 60rem;
    --article-rail-width: 17rem;
    --article-main-gap: clamp(1rem, 1.7vw, 1.5rem);
    --article-side-gutter: clamp(1rem, 3vw, 3.5rem);
    --article-rail-sticky-top: calc(env(safe-area-inset-top, 0px) + var(--nav-height, 3.35rem));
    --article-rail-bottom-gap: clamp(0.75rem, 2vh, 1.25rem);
  }

  .article-container {
    position: relative;
    margin: calc(-1 * (var(--nav-height, 3.35rem) + 1.25rem)) auto 0;
    max-width: none;
    padding: 0 0 clamp(1.5rem, 2vw + 0.65rem, 3rem);
  }

  .article-main {
    margin-top: clamp(-1.35rem, -1.8vw, -0.8rem);
    display: grid;
    grid-template-columns:
      minmax(var(--article-side-gutter), 1fr)
      minmax(0, var(--article-content-width))
      minmax(var(--article-rail-width), 1fr);
    gap: var(--article-main-gap);
    align-items: start;
    inline-size: 100dvw;
    margin-inline: calc(50% - 50dvw);
  }

  .article-body-column {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 3vw, 3rem);
    max-inline-size: var(--article-content-width);
    width: 100%;
    justify-self: stretch;
  }

  .article-main :global(.article-rail-sidebar) {
    grid-column: 3;
    justify-self: end;
    margin-right: var(--article-side-gutter);
  }

  .article-related {
    margin: clamp(3rem, 4vw, 4.25rem) auto 0;
    inline-size: min(100%, var(--article-content-width));
    max-width: var(--article-content-width);
  }

  @media (max-width: 1320px) {
    .article-main {
      inline-size: min(100%, var(--article-content-width));
      margin-inline: auto;
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
    }

    .article-body-column {
      display: contents;
    }

    .article-body-column :global(.article-brief) {
      order: 1;
    }

    .article-main :global(.article-rail-sidebar) {
      grid-column: auto;
      justify-self: stretch;
      margin-right: 0;
      order: 2;
    }

    .article-body-column :global(.article-body-container) {
      order: 3;
    }
  }

  @media (max-width: 1024px) {
    .article-main {
      inline-size: min(100%, var(--article-content-width));
      margin-inline: auto;
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
    }

    .article-body-column {
      display: contents;
    }

    .article-body-column :global(.article-brief) {
      order: 1;
    }

    .article-main :global(.article-rail-sidebar) {
      grid-column: auto;
      justify-self: stretch;
      margin-right: 0;
      order: 2;
    }

    .article-body-column :global(.article-body-container) {
      order: 3;
    }
  }

  @media (max-width: 720px) {
    .article-main {
      margin-top: clamp(-0.75rem, -2vw, -0.35rem);
    }

    .article-container {
      margin-top: calc(-1 * (var(--nav-height, 3.35rem) + 1rem));
      padding: 0 0 2.2rem;
    }
  }
</style>

<script>
  import '@/scripts/blog-post.ts';
</script>
