---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { Calendar, CircleUser, Clock3, Tag as TagIcon } from '@lucide/astro';
import FormattedDate from '@/components/content/FormattedDate';
import PageBackdrop from '@/components/layout/core/PageBackdrop.astro';
import ReadingProgressBar from '@/components/layout/core/ReadingProgressBar';
import Toc from '@/components/layout/blog/Toc.astro';
import BlogLanguageSwitcher from '@/components/ui/blog/BlogLanguageSwitcher';
import { languages } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { computeBlogPostMetadata, generateBlogPostSchema } from '@/lib/blog-post-schema';
import type { BlogPostLanguageState } from '@/lib/blog-translations';

type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  lang?: 'en' | 'th';
  wordCount?: number;
  readingTimeMin?: number;
  languageState: BlogPostLanguageState<CollectionEntry<'blog'>>;
  alternateLanguages?: { lang: 'en' | 'th'; href: string }[];
};

const {
  title,
  excerpt,
  pubDate,
  coverImage,
  tags,
  slug,
  lang = 'en',
  wordCount,
  readingTimeMin,
  seriesSlug,
  seriesTitle,
  seriesOrder,
  languageState,
  alternateLanguages = [],
} = Astro.props as Props;

const t = useTranslations(lang);
const languageHelperText = !languageState.availability.en.available
  ? t('blog.onlyInThai')
  : !languageState.availability.th.available
    ? t('blog.onlyInEnglish')
    : undefined;

const twitterHandle = (import.meta.env as any)['PUBLIC_TWITTER_HANDLE'] as string | undefined;
const metadata = computeBlogPostMetadata({
  slug,
  lang,
  coverImage,
  tags,
  site: Astro.site,
  twitterHandle,
});
const {
  canonicalUrl,
  imageUrl,
  authorUrl,
  authorSameAs,
  coverOrientation,
  visibleTags,
  hiddenTagCount,
} = metadata;

const siteUrl = Astro.site ? Astro.site.href : '/';
const schema = generateBlogPostSchema({
  title,
  excerpt,
  pubDate,
  wordCount,
  canonicalUrl,
  imageUrl,
  authorUrl,
  authorSameAs,
  siteUrl,
  seriesSlug,
  seriesTitle,
  seriesOrder,
});
---

<BaseLayout
  title={`${title} - PETEPITTAWAT.DEV`}
  description={excerpt}
  lang={lang}
  alternateLanguages={alternateLanguages}
  image={coverImage?.src ?? (slug ? `/og/blog/${slug}.png` : undefined)}
  type="article"
  publishedTime={pubDate.toISOString?.() ?? String(pubDate)}
  tags={tags}
  wordCount={wordCount}
  page="blog"
>
  <PageBackdrop variant="article" />
  <ReadingProgressBar />
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </Fragment>

  <div class="article-container">
    <div class="article-back">
      <a href="/blog" class="article-back__link">
        <span class="article-back__icon" aria-hidden="true">←</span>
        All posts
      </a>
    </div>

    <section
      class="article-surface article-hero reveal"
      data-has-media={coverImage ? 'true' : undefined}
    >
      <div class="article-hero__copy">
        <div class="article-hero__badge">
          <span class="article-hero__badge-dot"></span>
          Field Notes
        </div>
        <h1 class="article-hero__title">{title}</h1>
        <div class="article-meta">
          <div class="article-meta__item">
            <span class="sr-only">Published</span>
            <Calendar class="article-meta__icon" aria-hidden="true" />
            <span class="article-meta__text"><FormattedDate date={pubDate} /></span>
          </div>
          <div class="article-meta__divider" aria-hidden="true">·</div>
          <div class="article-meta__item">
            <span class="sr-only">Author</span>
            <CircleUser class="article-meta__icon" aria-hidden="true" />
            <span class="article-meta__text">Pete</span>
          </div>
          {
            typeof readingTimeMin === 'number' ? (
              <>
                <div class="article-meta__divider" aria-hidden="true">
                  ·
                </div>
                <div class="article-meta__item">
                  <span class="sr-only">Reading time</span>
                  <Clock3 class="article-meta__icon" aria-hidden="true" />
                  <span class="article-meta__text">{readingTimeMin} min read</span>
                </div>
              </>
            ) : null
          }
        </div>

        {
          visibleTags.length ? (
            <div class="article-tags">
              <span class="article-tags__icon">
                <span class="sr-only">Tags</span>
                <TagIcon class="article-tags__symbol" aria-hidden="true" />
              </span>
              <ul class="article-tags__list">
                {visibleTags.map(tag => (
                  <li>
                    <a
                      href={`/tags/${tag
                        .toLowerCase()
                        .trim()
                        .replace(/[^a-z0-9]+/g, '-')
                        .replace(/(^-|-$)/g, '')}`}
                      class="article-tag"
                    >
                      #{tag}
                    </a>
                  </li>
                ))}
                {hiddenTagCount > 0 ? (
                  <li>
                    <span class="article-tag article-tag--muted">+{hiddenTagCount} more</span>
                  </li>
                ) : null}
              </ul>
            </div>
          ) : null
        }
      </div>

      {
        coverImage && (
          <div class="article-hero__media" data-orientation={coverOrientation}>
            <Image
              class="article-hero__media-img"
              src={coverImage}
              alt=""
              loading="eager"
              fetchpriority="high"
              sizes="(min-width: 1280px) 420px, (min-width: 1024px) 36vw, (min-width: 768px) 60vw, 100vw"
              decoding="async"
              data-orientation={coverOrientation}
            />
          </div>
        )
      }
    </section>

    <div class="article-main">
      <aside class="article-surface article-rail reveal">
        <BlogLanguageSwitcher
          ariaLabel="Select reading language"
          label="Reading language"
          variant="rail"
          helperText={languageHelperText}
          options={[
            {
              locale: 'en',
              label: languages.en,
              shortLabel: 'EN',
              href: languageState.availability.en.href,
              available: languageState.availability.en.available,
              isActive: languageState.availability.en.isCurrent,
              screenReaderLabel: languageState.availability.en.available
                ? 'Read this post in English'
                : 'English translation unavailable',
            },
            {
              locale: 'th',
              label: languages.th,
              shortLabel: 'TH',
              href: languageState.availability.th.href,
              available: languageState.availability.th.available,
              isActive: languageState.availability.th.isCurrent,
              screenReaderLabel: languageState.availability.th.available
                ? 'Read this post in Thai'
                : 'Thai translation unavailable',
            },
          ]}
        />

        {
          excerpt ? (
            <section class="article-note" aria-labelledby="article-note-heading">
              <div class="article-note__eyebrow" id="article-note-heading">
                TL;DR
              </div>
              <p class="article-note__copy">{excerpt}</p>
            </section>
          ) : null
        }

        <div class="article-rail__toc">
          <Toc title="On this page" selector="#post-article" levels={[2, 3]} collapsed={true} />
        </div>
      </aside>

      <div class="article-surface article-body-card reveal">
        <article
          id="post-article"
          class="article-body prose prose-invert prose-a:text-[color:var(--accent)] hover:prose-a:underline prose-a:underline-offset-2 prose-img:rounded-xl prose-pre:text-sm prose-code:text-[0.95em] prose-code:before:content-[''] prose-code:after:content-[''] prose-h1:text-3xl prose-h2:text-2xl lg:prose-h1:text-4xl lg:prose-h2:text-3xl prose-headings:mt-10 prose-headings:mb-4 prose-headings:scroll-mt-28 md:prose-headings:scroll-mt-32 prose-p:leading-8"
        >
          <slot />
        </article>
      </div>
    </div>
  </div>

  <div class="article-related">
    <slot name="after" />
  </div>
</BaseLayout>

<style>
  .article-container {
    position: relative;
    margin: 0 auto;
    max-width: min(74rem, 100%);
    padding: clamp(1.5rem, 2vw + 0.65rem, 3rem) 0;
  }

  .article-surface {
    position: relative;
    overflow: hidden;
    border-radius: 1.9rem;
    border: 1px solid color-mix(in oklab, var(--white) 10%, transparent);
    background:
      radial-gradient(
        150% 150% at 12% 0%,
        color-mix(in oklab, var(--accent-blog) 18%, transparent),
        transparent 58%
      ),
      linear-gradient(180deg, rgba(8, 13, 27, 0.92), rgba(5, 9, 20, 0.96));
    box-shadow: 0 30px 80px -64px rgba(4, 10, 24, 0.92);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    isolation: isolate;
  }

  .article-surface::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 140% at 80% 12%, rgba(126, 165, 255, 0.12), transparent 58%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 28%);
    opacity: 0.9;
  }

  .article-back {
    margin-bottom: clamp(1.4rem, 1.8vw, 2rem);
  }

  .article-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.35rem 0;
    color: color-mix(in oklab, var(--white) 82%, transparent);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent-blog) 24%, transparent);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .article-back__link:hover {
    transform: translateX(-2px);
    color: color-mix(in oklab, var(--accent-blog) 80%, var(--white) 30%);
    border-color: color-mix(in oklab, var(--accent-blog) 50%, transparent);
  }

  .article-back__icon {
    font-size: 1rem;
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.88fr);
    gap: clamp(1.6rem, 2vw, 2.6rem);
    padding: clamp(1.5rem, 2vw + 0.7rem, 2.4rem);
    align-items: stretch;
  }

  .article-hero__copy {
    position: relative;
    z-index: 1;
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    gap: 1.2rem;
  }

  .article-hero__badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.6rem;
    padding: 0.52rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--white) 14%, transparent);
    background: color-mix(in oklab, var(--white) 5%, transparent);
    color: color-mix(in oklab, var(--white) 78%, transparent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .article-hero__badge-dot {
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent-blog) 84%, transparent);
    box-shadow: 0 0 14px rgba(129, 140, 248, 0.55);
  }

  .article-hero__title {
    margin: 0;
    max-width: 18ch;
    font-size: clamp(2.2rem, 2rem + 1.4vw, 4rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.028em;
    text-wrap: balance;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    font-size: 0.9rem;
    color: color-mix(in oklab, var(--white) 74%, transparent);
  }

  .article-meta__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .article-meta__icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.74;
  }

  .article-meta__text {
    font-weight: 600;
    color: color-mix(in oklab, var(--white) 88%, transparent);
  }

  .article-meta__divider {
    opacity: 0.3;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .article-tags__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--white) 12%, transparent);
    background: color-mix(in oklab, var(--white) 6%, transparent);
  }

  .article-tags__symbol {
    width: 1rem;
    height: 1rem;
    color: color-mix(in oklab, var(--accent-blog) 82%, white 16%);
  }

  .article-tags__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.42rem 0.82rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--accent-blog) 32%, transparent);
    background: rgba(18, 28, 52, 0.72);
    color: color-mix(in oklab, var(--accent-blog) 86%, white 14%);
    font-size: 0.78rem;
    font-weight: 600;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .article-tag:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--accent-blog) 48%, transparent);
    background: rgba(26, 38, 69, 0.82);
  }

  .article-tag--muted {
    border-color: rgba(148, 163, 184, 0.18);
    background: rgba(18, 26, 46, 0.64);
    color: color-mix(in oklab, var(--white) 72%, transparent);
  }

  .article-hero__media {
    position: relative;
    z-index: 1;
    min-height: clamp(16rem, 28vw, 24rem);
    overflow: hidden;
    border-radius: 1.35rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background:
      linear-gradient(180deg, rgba(4, 8, 18, 0.08), rgba(4, 8, 18, 0.4)), rgba(255, 255, 255, 0.04);
    box-shadow: 0 24px 56px -44px rgba(4, 10, 24, 0.92);
  }

  .article-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(4, 8, 18, 0) 30%, rgba(4, 8, 18, 0.26) 100%);
    pointer-events: none;
  }

  .article-hero__media-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .article-hero__media[data-orientation='portrait'] .article-hero__media-img {
    object-position: top center;
  }

  .article-main {
    margin-top: clamp(1.5rem, 2vw, 2.25rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.25rem, 1.8vw, 2rem);
    align-items: start;
  }

  .article-rail {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .article-note {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.7rem;
    padding: 1rem 1rem 1.05rem;
    border-radius: 1.3rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: linear-gradient(180deg, rgba(13, 21, 39, 0.88), rgba(8, 13, 26, 0.92));
  }

  .article-note__eyebrow {
    display: inline-flex;
    width: fit-content;
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(129, 140, 248, 0.28);
    background: rgba(79, 112, 207, 0.16);
    color: color-mix(in oklab, var(--accent-blog) 84%, white 18%);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .article-note__copy {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.75;
    color: color-mix(in oklab, var(--white) 84%, transparent);
    text-wrap: pretty;
  }

  .article-rail__toc {
    position: relative;
    z-index: 1;
  }

  .article-body-card {
    padding: clamp(1.6rem, 1.8vw + 1rem, 2.4rem);
  }

  .article-rail :global(.toc-root) {
    width: 100%;
  }

  .article-rail :global(.toc-card) {
    border-radius: 1.35rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: linear-gradient(180deg, rgba(12, 19, 35, 0.92), rgba(8, 13, 25, 0.96));
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .article-rail :global(.toc-summary) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: center;
    padding: 1rem 1rem 0.95rem;
    cursor: pointer;
    list-style: none;
    color: color-mix(in oklab, var(--white) 88%, transparent);
  }

  .article-rail :global(.toc-summary::-webkit-details-marker) {
    display: none;
  }

  .article-rail :global(.toc-summary__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.85rem;
    border: 1px solid rgba(129, 140, 248, 0.2);
    background: rgba(79, 112, 207, 0.14);
    color: color-mix(in oklab, var(--accent-blog) 82%, white 16%);
  }

  .article-rail :global(.toc-summary__content) {
    display: grid;
    gap: 0.25rem;
  }

  .article-rail :global(.toc-summary__label) {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .article-rail :global(.toc-summary__count) {
    font-size: 0.8rem;
    color: color-mix(in oklab, var(--white) 58%, transparent);
  }

  .article-rail :global(.toc-summary__action) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--white) 54%, transparent);
  }

  .article-rail :global(.toc-summary__chevron) {
    width: 0.95rem;
    height: 0.95rem;
    transition: transform 220ms ease;
  }

  .article-rail :global(.toc-card[open] .toc-summary__chevron) {
    transform: rotate(180deg);
  }

  .article-rail :global(.toc-panel) {
    padding: 0 1rem 1rem;
  }

  .article-rail :global(.toc-list) {
    margin: 0;
    padding: 0.85rem 0 0;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    display: grid;
    gap: 0.7rem;
    list-style: none;
  }

  .article-rail :global(.toc-row) {
    display: block;
    position: relative;
  }

  .article-rail :global(.toc-row--sub) {
    margin-left: 0.9rem;
    padding-left: 0.85rem;
  }

  .article-rail :global(.toc-row--sub::before) {
    content: '';
    position: absolute;
    left: 0.15rem;
    top: 0.75rem;
    bottom: 0.75rem;
    width: 1px;
    background: rgba(129, 140, 248, 0.2);
  }

  .article-rail :global(.toc-link) {
    display: inline-flex;
    width: 100%;
    align-items: center;
    gap: 0.6rem;
    color: color-mix(in oklab, var(--white) 88%, transparent);
    font-size: 0.9rem;
    line-height: 1.4;
    text-decoration: none;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .article-rail :global(.toc-link:hover) {
    color: color-mix(in oklab, var(--accent) 58%, var(--white) 42%);
    transform: translateX(2px);
  }

  .article-rail :global(.toc-link:focus-visible) {
    outline: none;
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 40%, transparent);
    border-radius: 999px;
    padding: 0.12rem 0.32rem;
    margin: -0.12rem -0.32rem;
  }

  .article-rail :global(.toc-link--sub) {
    font-size: 0.84rem;
    color: color-mix(in oklab, var(--white) 70%, transparent);
  }

  .article-rail :global(.toc-icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    background: rgba(129, 140, 248, 0.12);
  }

  .article-body {
    margin: 0 auto;
    max-width: 100%;
    font-family: 'Noto Serif Thai', 'Noto Serif', serif;
    font-size: clamp(1.06rem, 1.02rem + 0.34vw, 1.22rem);
    line-height: 1.88;
    letter-spacing: 0.01em;
    font-feature-settings: 'kern', 'liga';
    text-rendering: optimizeLegibility;
    text-wrap: pretty;
    color: color-mix(in oklab, var(--white) 94%, transparent);
  }

  .article-body :global(> *:first-child) {
    margin-top: 0;
  }

  .article-body :global(> *:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(p) {
    color: color-mix(in oklab, var(--white) 90%, transparent);
    margin-top: 1.15em;
    margin-bottom: 1.15em;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.45em;
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    color: color-mix(in oklab, var(--white) 90%, transparent);
  }

  .article-body :global(ul li::marker) {
    color: color-mix(in oklab, var(--accent) 55%, var(--white) 40%);
  }

  .article-body :global(ol li::marker) {
    color: color-mix(in oklab, var(--accent) 64%, var(--white) 36%);
    font-weight: 600;
  }

  .article-body :global(li + li) {
    margin-top: 0.55em;
  }

  .article-body :global(blockquote) {
    position: relative;
    border-left: 0.2rem solid color-mix(in oklab, var(--accent-blog) 42%, transparent);
    padding-left: 1.2rem;
    margin: 2.1em 0;
    color: color-mix(in oklab, var(--white) 84%, transparent);
    font-size: 1.02em;
    font-style: italic;
    background: linear-gradient(120deg, rgba(18, 27, 49, 0.82), rgba(13, 22, 42, 0.68));
    border-radius: 1.05rem;
    padding-block: 1.2rem;
    padding-right: 1.4rem;
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.08);
  }

  .article-body :global(blockquote)::before {
    content: '“';
    position: absolute;
    font-size: 4rem;
    line-height: 1;
    opacity: 0.08;
    left: 0.6rem;
    top: -0.8rem;
    pointer-events: none;
  }

  .article-body :global(hr) {
    border: none;
    height: 1.5px;
    margin: 3.5rem auto;
