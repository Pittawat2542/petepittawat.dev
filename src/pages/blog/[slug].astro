---
import { getCollection } from 'astro:content';
import Page from '@/components/pages/BlogPostPage.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const groups = allPosts.reduce(
    (acc, post) => {
      const key = post.data.translationId || post.data.slug;
      if (!acc[key]) acc[key] = [];
      acc[key].push(post);
      return acc;
    },
    {} as Record<string, CollectionEntry<'blog'>[]>
  );

  return Object.values(groups).map(group => {
    const enPost = group.find(p => p.data.lang === 'en');
    const thPost = group.find(p => p.data.lang === 'th');

    // The post to display on the English route
    const displayPost = enPost || thPost;

    return {
      params: { slug: displayPost!.data.slug },
      props: {
        post: displayPost!,
        isTranslationFallback: !enPost && !!thPost,
        ...(thPost && enPost !== thPost ? { otherLanguageSlug: thPost.data.slug } : {}),
      },
    };
  });
}

const props = Astro.props;
---

<Page {...props} />
