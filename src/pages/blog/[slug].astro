---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import RelatedPosts from '@/components/content/RelatedPosts';
import { estimateReadingMetrics } from '@/lib/reading-time';
import BlogPost from '@/layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props as Props;
const { Content } = await render(post);
const { wordCount, readingTimeMin } = estimateReadingMetrics(post.body || '');

const all = (await getCollection('blog')) as CollectionEntry<'blog'>[];
const related = all
  .filter(p => p.id !== post.id && p.data.tags.some(t => post.data.tags.includes(t)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BlogPost
  {...post.data}
  slug={post.data.slug}
  wordCount={wordCount}
  readingTimeMin={readingTimeMin}
>
  <Content />

  <Fragment slot="after">
    <RelatedPosts posts={related} />
  </Fragment>
</BlogPost>
