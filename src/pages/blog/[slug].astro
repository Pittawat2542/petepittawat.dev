---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import RelatedPosts from '@/components/content/RelatedPosts';
import { estimateReadingMetrics } from '@/lib/reading-time';
import BlogPost from '@/layouts/BlogPost.astro';
import { getSuggestedReading } from '@/lib/blog-recommendations';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props as Props;
const { Content } = await render(post);
const { wordCount, readingTimeMin } = estimateReadingMetrics(post.body || '');

const all = (await getCollection('blog')) as CollectionEntry<'blog'>[];
const suggestedReading = getSuggestedReading(all, post);
---

<BlogPost
  {...post.data}
  slug={post.data.slug}
  wordCount={wordCount}
  readingTimeMin={readingTimeMin}
>
  <Content />

  <Fragment slot="after">
    <RelatedPosts suggestions={suggestedReading} />
  </Fragment>
</BlogPost>
