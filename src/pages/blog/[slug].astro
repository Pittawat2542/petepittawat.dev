---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import RelatedPosts from '@/components/content/RelatedPosts';
import BlogPost from '@/layouts/BlogPost.astro';
import { getSuggestedReading } from '@/lib/blog-recommendations';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props as Props;
const { Content } = await render(post);
// Rough reading time estimate (~220 wpm)
const wordCount = (post.body || '').trim().split(/\s+/).length;
const readingTimeMin = Math.max(1, Math.round(wordCount / 220));

const all = (await getCollection('blog')) as CollectionEntry<'blog'>[];
const suggestedReading = getSuggestedReading(all, post);
---

<BlogPost {...post.data} slug={post.data.slug} readingTimeMin={readingTimeMin}>
  <Content />

  <Fragment slot="after">
    <RelatedPosts suggestions={suggestedReading} />
  </Fragment>
</BlogPost>
