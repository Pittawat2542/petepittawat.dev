---
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import { getCollection } from 'astro:content';
import EditorialPageHero from '@/components/layout/core/EditorialPageHero.astro';
import Container from '@/components/ui/core/Container.astro';
import BlogListPage from '@/components/layout/BlogListPage';
import BaseLayout from '@/layouts/BaseLayout.astro';

import { toCompactBlogPosts } from '@/lib/compact';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const compactPosts = toCompactBlogPosts(allPosts);
---

<BaseLayout title={`${SITE_TITLE} - Blog`} description={SITE_DESCRIPTION} page="blog">
  <Container className="space-y-8 md:space-y-10">
    <EditorialPageHero
      eyebrow="Field Notes"
      title="Blog"
      subtitle="Explore my thoughts, tutorials, and insights on technology, programming, and AI."
    />
    <BlogListPage client:idle posts={compactPosts} initialLocale="en" />
  </Container>
</BaseLayout>
