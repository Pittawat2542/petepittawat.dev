---
import { SITE_CONFIG } from '@/lib/constants';
import { ProjectsExplorer } from '@/components/explorers';
import EditorialPageHero from '@/components/layout/core/EditorialPageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/core/Container.astro';
import { siteCopyEn } from '@/data/site/copy';
import { getProjects } from '@/lib/content';

const pageCopy = siteCopyEn.listingPages.projects;
const projects = await getProjects();
---

<BaseLayout
  title={`${SITE_CONFIG.title} - ${pageCopy.title}`}
  description={pageCopy.metaDescription || SITE_CONFIG.description}
  page="projects"
>
  <Container className="space-y-8 md:space-y-10">
    <EditorialPageHero
      eyebrow="Selected Work"
      title={pageCopy.title}
      subtitle={pageCopy.heroSubtitle}
      variant="showcase"
      visualPreset="projects"
    >
      <div slot="support" class="listing-hero-support" aria-label="Project themes">
        <span class="listing-hero-support__item">AI tooling</span>
        <span class="listing-hero-support__item">Research prototypes</span>
        <span class="listing-hero-support__item">Learning systems</span>
      </div>
    </EditorialPageHero>
    <ProjectsExplorer client:idle items={projects} />
  </Container>
</BaseLayout>
