---
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import { PublicationsExplorer } from '@/components/explorers';
import academicServices from '@/data/services/academic.json';
import AcademicServices from '@/components/sections/AcademicServices.astro';
import EditorialPageHero from '@/components/layout/core/EditorialPageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/core/Container.astro';
import { siteCopyEn } from '@/data/site/copy';
import { getPublications } from '@/lib/content';

const pageCopy = siteCopyEn.listingPages.publications;
const publications = await getPublications();
---

<BaseLayout
  title={`${SITE_TITLE} - ${pageCopy.title}`}
  description={pageCopy.metaDescription || SITE_DESCRIPTION}
  page="publications"
>
  <Container className="space-y-8 md:space-y-10">
    <EditorialPageHero
      eyebrow="Research Record"
      title={pageCopy.title}
      subtitle={pageCopy.heroSubtitle}
      variant="showcase"
    >
      <div slot="support" class="listing-hero-support" aria-label="Publication themes">
        <span class="listing-hero-support__item">Reasoning models</span>
        <span class="listing-hero-support__item">Evaluation</span>
        <span class="listing-hero-support__item">Thai NLP</span>
      </div>
    </EditorialPageHero>
    <PublicationsExplorer client:idle items={publications} />
    <AcademicServices
      data={academicServices}
      title={pageCopy.academicServicesTitle}
      description={pageCopy.academicServicesDescription}
    />
  </Container>
</BaseLayout>
