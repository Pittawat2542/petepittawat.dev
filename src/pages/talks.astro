---
import { SITE_CONFIG } from '@/lib/constants';
import { TalksExplorer } from '@/components/explorers';
import EditorialPageHero from '@/components/layout/core/EditorialPageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/core/Container.astro';
import { siteCopyEn } from '@/data/site/copy';
import { getTalks } from '@/lib/content';

const pageCopy = siteCopyEn.listingPages.talks;
const talks = await getTalks();
---

<BaseLayout
  title={`${SITE_CONFIG.title} - ${pageCopy.title}`}
  description={pageCopy.metaDescription || SITE_CONFIG.description}
  page="talks"
>
  <Container className="space-y-8 md:space-y-10">
    <EditorialPageHero
      eyebrow="Speaking"
      title={pageCopy.title}
      subtitle={pageCopy.heroSubtitle}
      variant="showcase"
      visualPreset="talks"
    >
      <div slot="support" class="listing-hero-support" aria-label="Talk themes">
        <span class="listing-hero-support__item">Invited sessions</span>
        <span class="listing-hero-support__item">Workshops</span>
        <span class="listing-hero-support__item">AI engineering</span>
      </div>
    </EditorialPageHero>
    <TalksExplorer client:idle items={talks} />
  </Container>
</BaseLayout>
