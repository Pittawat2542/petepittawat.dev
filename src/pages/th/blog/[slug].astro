---
import { getCollection } from 'astro:content';
import Page from '@/components/pages/BlogPostPage.astro';
import type { CollectionEntry } from 'astro:content';
import {
  getAlternateBlogPost,
  getBlogPostsForLocale,
  groupBlogPostsByTranslation,
} from '@/lib/blog-translations';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const groups = groupBlogPostsByTranslation(allPosts as CollectionEntry<'blog'>[]);

  return getBlogPostsForLocale(groups, 'th').map(post => {
    const alternatePost = getAlternateBlogPost(post, groups);

    return {
      params: { slug: post.data.slug },
      props: {
        post,
        ...(alternatePost ? { alternatePost } : {}),
      },
    };
  });
}

const props = Astro.props;
---

<Page {...props} />
